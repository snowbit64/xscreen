<?xml version="1.0" encoding="utf-8"?>

<Gui>

    <Profiles>

        <Profile name="mainButton">
            <Property name="width" value="0.3"/>
            <Property name="height" value="60px"/>
            <Property name="fontSize" value="22"/>
            <Property name="bgColor" value="0.18 0.35 0.18 1.0"/>
            <Property name="cornerRadius" value="6"/>
        </Profile>

        <Profile name="titleLabel">
            <Property name="fontSize" value="42"/>
            <Property name="textColor" value="0.9 0.95 0.85 1.0"/>
            <Property name="height" value="60px"/>
        </Profile>

        <Profile name="subtitleLabel">
            <Property name="fontSize" value="16"/>
            <Property name="textColor" value="0.6 0.65 0.55 1.0"/>
            <Property name="height" value="30px"/>
        </Profile>

    </Profiles>

    <Screen
        name="MainMenu"
        script="ui/scripts/mainMenu.lua">

        <VBox
            width="0.4"
            height="0.7"
            align="center"
            alignY="center"
            spacing="12"
            padding="20">

            <Label
                id="titleLabel"
                text="South American Farming"
                profile="titleLabel"
                align="center"/>

            <Label
                id="subtitleLabel"
                text="Welcome to the farm"
                profile="subtitleLabel"
                align="center"/>

            <Button
                id="careerButton"
                profile="mainButton"
                text="Career"
                onClick="onCareerClick"/>

            <Button
                id="settingsButton"
                profile="mainButton"
                text="Settings"
                onClick="onSettingsClick"/>

            <Button
                id="testButton"
                profile="mainButton"
                text="UI Test Screen"
                onClick="onTestScreenClick"/>

            <Button
                id="quitButton"
                profile="mainButton"
                text="Quit"
                onClick="onQuitClick"
                bgColor="0.4 0.15 0.15 1.0"
                hoverColor="0.5 0.2 0.2 1.0"/>

        </VBox>

    </Screen>

</Gui>
