<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuHelpLine">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="130px -60px">
            <GuiElement type="bitmap" profile="ingameMenuHelpHeaderIcon" position="0px 0px"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" text="$l10n_ui_ingameMenuHelpLine"/>
        </GuiElement>

        <GuiElement type="empty" profile="emptyPanel" position="130px -124px" size="1660px 708px" screenAlign="topLeft" positionOrigin="topLeft" id="helpContainer" >
            <!-- Navigation Box -->
            <GuiElement type="empty" profile="ingameMenuHelpNavigationBox" position="0px 0px">
                <GuiElement type="list" profile="ingameMenuHelpList" position="1px -1px" onSelectionChanged="onHelpLineListSelectionChanged" onDoubleClick="onHelpLineDoubleClick" id="helpLineList" focusInit="onOpen">
                    <GuiElement type="listItem" profile="ingameMenuHelpListItem" id="helpLineListItemTemplate">
                        <GuiElement type="text" profile="helpLineListItemText" text="Help Line Title" name="listItemText"/>
                    </GuiElement>
                    <GuiElement type="listItem" profile="ingameMenuHelpListCategory" id="helpLineListCategoryTemplate">
                        <GuiElement type="text" profile="ingameMenuHelpListCategoryTitle" text="Help Line Title" name="listItemText"/>
                    </GuiElement>
                </GuiElement>

                <GuiElement type="bitmap" profile="verticalGlassListSliderBackground" size="28px 703px" position="-1px -1px">
                    <GuiElement type="slider" profile="verticalGlassListSlider" size="16px 691px" dataElementId="helpLineList" handleFocus="false" />
                </GuiElement>
            </GuiElement>

            <!-- Content Box -->
            <GuiElement type="empty" profile="ingameMenuHelpContentBox" position="475px 0px">
                <GuiElement type="text" profile="helpLineTitle" id="helpLineTitleElement" />

                <GuiElement type="boxLayout" profile="helpLineContentBox" position="40px -90px" id="helpLineContentBox" >
                    <GuiElement type="text"   profile="helpLineText"  id="helpLineTextElement" />
                    <GuiElement type="bitmap" profile="helpLineImage" id="helpLineImageElement" />
                </GuiElement>
            </GuiElement>
        </GuiElement>

    </GuiElement>
</GUI>
