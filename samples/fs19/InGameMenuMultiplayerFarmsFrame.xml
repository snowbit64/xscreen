<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuMultiplayerFarms">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="130px -60px">
            <GuiElement type="bitmap" profile="ingameMenuMPFarmsIcon" position="0px 0px"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" text="$l10n_ui_ingameMenuMultiplayerFarms"/>
        </GuiElement>

        <!-- Farms List -->
        <GuiElement type="list" profile="ingameMenuMPFarmsList" position="0px -50px" onClick="onClickFarm" onDoubleClick="onDoubleClickFarm" onSelectionChanged="onSelectionChanged" id="farmList" onScroll="onScroll">
            <!-- Farm Item Template -->
            <GuiElement type="listItem" profile="ingameMenuMPFarmsListItem" id="listTemplate">
                <GuiElement type="bitmap" profile="ingameMenuMPFarmsListItemFarmIcon" position="0px -47px" name="farmIcon"/>
                <GuiElement type="text" profile="ingameMenuMPFarmsListItemFarmName" position="0px -322px" name="farmName" text=""/>

                <GuiElement type="bitmap" profile="lineSeparator" screenAlign="topCenter" positionOrigin="topCenter" position="0px -362px" size="360px 1px"/>
            <GuiElement type="text" profile="ingameMenuMPFarmsListItemFarmBalance" position="0px -374px" name="farmBalance" text=""/>
                <GuiElement type="bitmap" profile="lineSeparator" screenAlign="topCenter" positionOrigin="topCenter" position="0px -418px" size="360px 1px"/>

                <GuiElement type="text" profile="ingameMenuMPFarmsListItemFarmPlayerCount" position="0px -434px" name="farmPlayerCount" text=""/>

                <GuiElement type="boxLayout" profile="ingameMenuMPFarmsListItemFarmPlayerNameLayout" position="0px -470px" name="playerNameLayout">
                    <GuiElement type="text" profile="ingameMenuMPFarmsListItemFarmPlayerName" name="playerNameTemplate" text=""/>
                </GuiElement>
            </GuiElement>

            <!-- New Farm Item -->
            <GuiElement type="listItem" profile="ingameMenuMPFarmsListItem" id="newFarmItem">
                <GuiElement type="bitmap" profile="ingameMenuMPFarmsListItemFarmIcon" position="0px -47px"/>
                <GuiElement type="text" profile="ingameMenuMPFarmsListItemFarmName" textUpperCase="true" position="0px -322px" text="$l10n_ui_farmNew"/>

                <GuiElement type="bitmap" profile="lineSeparator" screenAlign="topCenter" positionOrigin="topCenter" position="0px -362px" size="360px 1px"/>

                <GuiElement type="text" profile="ingameMenuMPFarmsListItemFarmPlayerName" screenAlign="topCenter" positionOrigin="topCenter" position="0px -434px" size="400px 20px" text="$l10n_ui_createNewFarm"/>
            </GuiElement>
        </GuiElement>

        <GuiElement type="bitmap" profile="ingameMenuMPFarmsNoFarmsBox" id="noFarmsBox" position="0px -50px">
            <GuiElement type="text" profile="ingameMenuMPFarmsNoFarmsText" text="$l10n_ui_noFarmsCreated" />
        </GuiElement>

        <!-- Left / Right Navigation -->
        <GuiElement type="button" profile="ingameMenuContentButtonLeft" position="60px -50px" id="buttonLeft" onClick="onClickLeft"/>
        <GuiElement type="button" profile="ingameMenuContentButtonRight" position="-60px -50px" id="buttonRight" onClick="onClickRight"/>
    </GuiElement>
</GUI>
