<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="settingsHDR">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="130px -60px">
            <GuiElement type="bitmap" profile="ingameMenuDisplaySettingsHeaderIcon" position="0px 0px"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" text="$l10n_setting_hdr"/>
        </GuiElement>

        <!-- Layouted settings box -->
        <GuiElement type="bitmap" profile="mainMenuSettingsBoxHDR" position="130px -124px" id="settingsContainer">
            <GuiElement type="bitmap" profile="hdrSettingsBox">
                <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickHDRPeakBrightness" onCreate="onCreateHDRPeakBrightness" id="HDRPeakBrightnessElement" focusInit="onOpen" screenAlign="topLeft" positionOrigin="topLeft" position="35px -50px" size="226px 48px">
                    <GuiElement type="button" profile="multiTextOptionLeft" />
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_hdrPeakBrightness"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" size="130px 48px"/>
                </GuiElement>
            </GuiElement>
            <GuiElement type="bitmap" profile="hdrImageBox" position="-105px 0px">
                <GuiElement type="clear" imageUVs="0 0 1 1" screenAlign="middleCenter" positionOrigin="middleCenter" size="1208px 680px" position="1dp 4dp" id="hdrImage" visible="true" />
            </GuiElement>
        </GuiElement>
    </GuiElement>
</GUI>
