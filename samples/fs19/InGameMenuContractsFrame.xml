<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuContracts">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="130px -60px">
            <GuiElement type="bitmap" profile="ingameMenuContractsHeaderIcon" position="0px 0px"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" text="$l10n_ui_contracts"/>
        </GuiElement>

        <GuiElement type="empty" profile="emptyPanel" position="130px -124px" size="1660px 708px" screenAlign="topLeft" positionOrigin="topLeft" id="contractsContainer">
            <GuiElement type="bitmap" profile="ingameMenuContractsListBox" id="contractsListBox">

                <GuiElement type="stableList" profile="ingameMenuContractsList" position="1px -1px" itemTemplateId="contractsListItemTemplate" onSelectionChanged="onListSelectionChanged" id="contractsList" focusInit="onOpen">
                    <GuiElement type="listItem" profile="ingameMenuContractsListItem" id="contractsListItemTemplate">

                        <GuiElement type="text" profile="ingameMenuContractsListItemContract" name="contract" />
                        <GuiElement type="text" profile="ingameMenuContractsListItemReward" name="reward" />
                        <GuiElement type="text" profile="ingameMenuContractsListItemField" name="field" />

                        <GuiElement type="text" profile="ingameMenuContractsListItemIndicatorActive" text="$l10n_fieldJob_active" name="indicatorActive" />
                        <GuiElement type="text" profile="ingameMenuContractsListItemIndicatorFinished" text="$l10n_fieldJob_finished" name="indicatorFinished" />
                        <GuiElement type="text" profile="ingameMenuContractsListItemIndicatorFailed" text="$l10n_fieldJob_failed" name="indicatorFailed" />

                    </GuiElement>
                </GuiElement>

                <GuiElement type="bitmap" profile="verticalGlassListSliderBackground" size="28px 703px" position="-1px -1px">
                    <GuiElement type="slider" profile="verticalGlassListSlider" size="16px 691px" dataElementId="contractsList" handleFocus="false"/>
                </GuiElement>
            </GuiElement>

            <GuiElement type="bitmap" profile="ingameMenuContractsDetailsBox" id="detailsBox">
                <GuiElement type="empty" profile="ingameMenuContractsFarmerBox" id="farmerBox">
                    <GuiElement type="bitmap" profile="ingameMenuContractsFarmerCircle">
                        <GuiElement type="bitmap" profile="ingameMenuContractsFarmerImage" id="farmerImage" />
                    </GuiElement>
                    <GuiElement type="text" profile="ingameMenuContractsFarmerText" id="farmerName" textBold="true" position="0px -281px" text="Benjarmin" />

                    <GuiElement type="empty" id="npcFieldBox" size="297px 300px" position="0px 90px" screenAlign="bottomCenter" positionOrigin="bottomCenter">
                        <GuiElement type="text" profile="ingameMenuContractsFarmerText" text="$l10n_ui_fieldOwnerOf" textBold="true" position="0px 0px" />
                        <GuiElement type="text" profile="ingameMenuContractsFarmerText" id="ownerOfText" position="0px -25px" text="Field 100"  />

                        <GuiElement type="text" profile="ingameMenuContractsFarmerText" text="$l10n_ui_fieldArea" textBold="true" position="0px -55px" />
                        <GuiElement type="text" profile="ingameMenuContractsFarmerText" id="areaText" position="0px -80px" text="100ha" />
                    </GuiElement>

                    <GuiElement type="bitmap" profile="ingameMenuContractsFarmerDivider" />
                </GuiElement>

                <GuiElement type="empty" profile="ingameMenuContractsContractBox" id="contractBox">
                    <GuiElement type="text" profile="ingameMenuContractsContractTitle" id="titleText" position="0px -50px" />

                    <GuiElement type="text" profile="ingameMenuContractsContractTextSmall" text="$l10n_fieldJob_desc_offersReward" position="0px -100px" />
                    <GuiElement type="text" profile="ingameMenuContractsContractTextBig" id="rewardText" position="0px -140px" />
                    <GuiElement type="text" profile="ingameMenuContractsContractTextSmall" id="actionText" position="0px -180px" />
                    <GuiElement type="text" profile="ingameMenuContractsContractTextBig" id="fieldBigText" position="0px -220px" />

                    <GuiElement type="text" profile="ingameMenuContractsContractTextSmall" id="progressTitleText" text="$l10n_fieldJob_progress" position="0px -340px" />
                    <GuiElement type="text" profile="ingameMenuContractsContractTextBig" id="progressText" position="0px -380px" />
                    <GuiElement type="text" profile="ingameMenuContractsContractTextSmall" id="extraProgressText" position="0px -500px" />

                    <GuiElement type="text" profile="ingameMenuContractsContractTextSmall" id="contractDescriptionText" textWrapWidth="700px" size="800px 50px" position="0px -280px" />
                    <GuiElement type="text" profile="ingameMenuContractsContractTextSmall" id="useOwnEquipementText" textWrapWidth="700px" size="800px 50px" position="0px -330px" />

                    <GuiElement type="bitmap" profile="ingameMenuContractsProgressBarBackground" position="0px -440px" id="progressBarBg">
                        <GuiElement type="bitmap" profile="ingameMenuContractsProgressBar" id="progressBar"/>
                    </GuiElement>

                    <GuiElement type="bitmap" profile="ingameMenuContractsVehiclesItem" id="vehicleTemplate">
                        <GuiElement type="text" profile="ingameMenuContractsVehiclesMoreItemsText" text="2+" name="more" visible="false" />
                    </GuiElement>
                    <GuiElement type="flowLayout" profile="ingameMenuContractsVehiclesBox" id="vehiclesBox" />
                </GuiElement>

                <GuiElement type="empty" profile="ingameMenuContractsTallyBox" id="tallyBox">
                    <GuiElement type="text" profile="ingameMenuContractsContractTitle" id="tallyTitle" position="0px -20px" text="$l10n_fieldJob_results" />

                    <GuiElement type="text" profile="ingameMenuContractsTallyKey" text="$l10n_fieldJob_tally_contract" position="0px -70px" />
                    <GuiElement type="text" profile="ingameMenuContractsTallyValue" name="reward" position="0px -70px" />

                    <GuiElement type="text" profile="ingameMenuContractsTallyKey" text="$l10n_fieldJob_tally_vehicleReduction" position="0px -110px" />
                    <GuiElement type="text" profile="ingameMenuContractsTallyValue" name="leaseCost" position="0px -110px" />

                    <GuiElement type="text" profile="ingameMenuContractsTallyKey" text="$l10n_fieldJob_tally_reimbursement" position="0px -150px" />
                    <GuiElement type="text" profile="ingameMenuContractsTallyValue" name="reimburse" position="0px -150px" />

                    <GuiElement type="text" profile="ingameMenuContractsTallyKey" text="$l10n_fieldJob_tally_stealing" position="0px -190px" />
                    <GuiElement type="text" profile="ingameMenuContractsTallyValue" name="stealing" position="0px -190px" />

                    <GuiElement type="bitmap" profile="ingameMenuContractsTallyLine" position="0px -230px" />
                    <GuiElement type="bitmap" profile="ingameMenuContractsTallyLine" position="0px -235px" />

                    <GuiElement type="text" profile="ingameMenuContractsTallyKey" text="$l10n_fieldJob_tally_total"  position="0px -245px" />
                    <GuiElement type="text" profile="ingameMenuContractsTallyValueColored" name="total"  position="0px -245px" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="bitmap" profile="ingameMenuContractsEmptyBox" id="noContractsBox">
                <GuiElement type="text" profile="ingameMenuContractsEmptyText" text="$l10n_fieldJob_noJobAvailable" />
            </GuiElement>
        </GuiElement>

    </GuiElement>
</GUI>
