<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="tutorial">
    <GuiElement type="empty" profile="uiElementContainerFullScreen" name="tutorial" id="pageTutorial">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="130px -60px">
            <GuiElement type="bitmap" profile="ingameMenuTutorialHeaderIcon" position="0px 0px"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" text="$l10n_ui_ingameMenuTutorial"/>
        </GuiElement>

        <GuiElement type="bitmap" profile="ingameMenuSettingsBox" position="130px -124px" id="mainFrameWrapper">
            <GuiElement type="list" profile="ingameMenuTutorialList" onSelectionChanged="onListSelectionChanged" id="tutorialList" focusInit="onOpen">
                <GuiElement type="listItem" profile="ingameMenuTutorialListItem" id="tutorialTemplate">
                    <GuiElement type="text" profile="ingameMenuTutorialListItemText" onCreate="onCreateItemText" />

                    <GuiElement type="bitmap" profile="ingameMenuTutorialListItemTick" name="tick" onCreate="onCreateItemTick">
                        <GuiElement type="bitmap" profile="tutorialItemTick"/>
                    </GuiElement>
                </GuiElement>
            </GuiElement>

            <GuiElement type="bitmap" profile="verticalGlassListSliderBackground" position="-1px -1px" size="28px 703px">
                <GuiElement type="slider" profile="verticalGlassListSlider" size="16px 691px" dataElementId="tutorialList" id="tutorialSlider" handleFocus="false" />
            </GuiElement>
        </GuiElement>

    </GuiElement>
</GUI>
