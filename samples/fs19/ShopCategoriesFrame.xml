<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="shopCategories">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="260px -60px">
            <GuiElement type="bitmap" profile="ingameMenuFinancesHeaderIcon" position="0px 0px" id="categoryHeaderIcon"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" id="categoryHeaderText"/>
        </GuiElement>

        <!-- Categories list -->
        <GuiElement type="list" profile="shopCategoryList" position="0px -60px" id="categoryList" onClick="onClickCategory" onDoubleClick="onDoubleClickCategory" onSelectionChanged="onCategorySelected" onScroll="onScroll">
            <!-- Category template -->
            <GuiElement type="listItem" profile="shopCategoryItem" id="categoryTemplate">
                <GuiElement type="empty" profile="shopCategoryItemImagePanel" position="0px 36px">
                    <GuiElement type="bitmap" profile="shopCategoryItemImage" name="categoryImage"/>
                </GuiElement>
                <GuiElement type="text" profile="shopCategoryItemText" position="0px -66px"  name="categoryText"/>
            </GuiElement>
        </GuiElement>

        <!-- View scroll buttons -->
        <GuiElement type="button" profile="ingameMenuContentButtonLeft" position="130px -60px" onClick="onClickLeft" id="buttonLeft"/>
        <GuiElement type="button" profile="ingameMenuContentButtonRight" position="-130px -60px" onClick="onClickRight" id="buttonRight"/>
    </GuiElement>
</GUI>
