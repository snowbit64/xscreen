<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="shopLandscaping">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="260px -60px">
            <GuiElement type="bitmap" profile="ingameMenuLandscapingHeaderIcon" position="0px 0px"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" text="$l10n_ui_landscaping"/>
        </GuiElement>

        <GuiElement type="empty" profile="ingameMenuLandscapingFrame" position="0px -60px" id="backgroundFrame">
            <!-- Start button -->
            <GuiElement type="bitmap" profile="ingameMenuLandscapingButtonFrame" position="0px 0px">
                <GuiElement type="button" profile="buttonOK" text="$l10n_button_startLandscaping" handleFocus="true" onClick="onClickStart" position="0px 0px" screenAlign="middleCenter" positionOrigin="middleCenter" id="buttonStart"/>
            </GuiElement>
        </GuiElement>
    </GuiElement>
</GUI>