<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="settingsDisplay">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="130px -60px">
            <GuiElement type="bitmap" profile="ingameMenuDisplaySettingsHeaderIcon" position="0px 0px"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" text="$l10n_ui_ingameMenuGameSettingsDisplay"/>
        </GuiElement>

        <!-- Layouted settings box -->
        <GuiElement type="bitmap" profile="mainMenuSettingsBox" position="130px -124px" id="settingsContainer">
            <GuiElement type="boxLayout" profile="ingameMenuSettingsLayoutTwoColumn" position="445px -50px" id="boxLayout">
                <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickPerformanceClass" onCreate="onCreatePerformanceClass" id="performanceClassElement" focusInit="onOpen">
                    <GuiElement type="button" profile="multiTextOptionLeft" />
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_hardwareProfile"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" />
                </GuiElement>
                <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickResolution" onCreate="onCreateResolution" id="resolutionElement">
                    <GuiElement type="button" profile="multiTextOptionLeft" />
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_resolution"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" />
                </GuiElement>
                <GuiElement type="checkedOption" profile="multiTextOptionSettings" onClick="onClickVSync" id="vSyncElement">
                    <GuiElement type="button" profile="multiTextOptionLeft"  />
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_vSync"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" />
                </GuiElement>
                <GuiElement type="checkedOption" profile="multiTextOptionSettings" onClick="onClickWindowMode" id="windowModeElement">
                    <GuiElement type="button" profile="multiTextOptionLeft" />
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_windowMode"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" />
                </GuiElement>
                <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickResolutionScale" onCreate="onCreateResolutioncale" id="resolutionScaleElement">
                    <GuiElement type="button" profile="multiTextOptionLeft" />
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_resolutionScaling"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" />
                </GuiElement>
                <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickBrightness" onCreate="onCreateBrightness" id="brightnessElement">
                    <GuiElement type="button" profile="multiTextOptionLeft" />
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_brightness"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" />
                </GuiElement>
                <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickFovY" onCreate="onCreateFovY" id="fovYElement">
                    <GuiElement type="button" profile="multiTextOptionLeft"/>
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_fovy"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" />
                </GuiElement>
                <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickUIScale" onCreate="onCreateUIScale" id="uiScaleElement">
                    <GuiElement type="button" profile="multiTextOptionLeft" />
                    <GuiElement type="button" profile="multiTextOptionRight" />
                    <GuiElement type="text"   profile="multiTextOptionText" />
                    <GuiElement type="text"   profile="multiTextOptionTitle" text="$l10n_setting_uiScale"/>
                    <GuiElement type="bitmap" profile="multiTextOptionBg" />
                </GuiElement>
                <GuiElement type="button" profile="settingsButton" onClick="onHDRCalibration" text="$l10n_setting_hdr" id="hdrCalibrationButton"/>
            </GuiElement>
        </GuiElement>
    </GuiElement>
</GUI>
