<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="empty" profile="newLayer" />
    <GuiElement type="bitmap" profile="dialogFullscreenBg" />

    <GuiElement type="bitmap" profile="sellDialogBg" id="dialogElement">
        <GuiElement type="bitmap" profile="dialogHeaderDocked">
            <GuiElement type="text" profile="dialogHeaderText" text="$l10n_ui_sellItem" id="headerText" />
        </GuiElement>

        <GuiElement type="bitmap" profile="sellDialogImage" id="dialogImageElement" />
        <GuiElement type="text" profile="sellDialogName" id="dialogItemNameElement" />
        <GuiElement type="text" profile="sellDialogText" text="$l10n_ui_sellValue:" id="valueText" />
        <GuiElement type="text" profile="sellDialogPrice" id="dialogItemPriceElement" />
        <GuiElement type="bitmap" profile="sellDialogNameSeparator" />

        <GuiElement type="flowLayout" profile="buttonBoxDialog" id="buttonsPC" >
            <GuiElement type="button" profile="buttonOK" text="$l10n_button_yes" onClick="onClickOk" id="yesButton" />
            <GuiElement type="button" profile="buttonBack" text="$l10n_button_no" onClick="onClickBack" id="noButton" />
        </GuiElement>
    </GuiElement>
</GUI>
