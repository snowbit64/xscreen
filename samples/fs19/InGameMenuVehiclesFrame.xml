<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="garageOverview">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel" position="130px -60px">
            <GuiElement type="bitmap" profile="ingameMenuGarageHeaderIcon" position="0px 0px"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="80px 0px" text="$l10n_ui_garageOverview"/>
        </GuiElement>

        <GuiElement type="empty" profile="ingameMenuSettingsBox" position="130px -124px" id="mainBox">

            <!-- Vehicle table header -->
            <GuiElement type="flowLayout" profile="ingameMenuPriceTableHeaderBox" position="1px 0px" focusId="focus_header" id="tableHeaderBox">
                <GuiElement type="tableHeader" profile="ingameMenuGarageTableHeaderVehicle" text="$l10n_ui_vehicle" targetTableId="vehicleTable" columnName="vehicleName" onClick="onClickVehicleHeader" focusId="focus_name_header" focusChangeBottom="focus_value_header" focusChangeTop="focus_age_header">
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortAscending" position="400px 0px" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortDescending" position="400px 0px" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="tableHeader" profile="ingameMenuGarageTableHeaderAge" targetTableId="vehicleTable" columnName="age" id="ageHeader" onClick="onClickAttributeHeader" focusId="focus_age_header" focusChangeLeft="focus_age_header">
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="tableHeader" profile="ingameMenuGarageTableHeaderOperatingHours" targetTableId="vehicleTable" columnName="operatingHours" id="operatingHoursHeader" onClick="onClickAttributeHeader" focusId="focus_operating_hours_header">
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="tableHeader" profile="ingameMenuGarageTableHeaderDamage" targetTableId="vehicleTable" columnName="damage" id="damageHeader" onClick="onClickAttributeHeader" focusId="focus_damage_header">
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="tableHeader" profile="ingameMenuGarageTableHeaderLeasing" targetTableId="vehicleTable" columnName="leasing" id="leasingHeader" onClick="onClickAttributeHeader" focusId="focus_leasing_header">
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="tableHeader" profile="ingameMenuGarageTableHeaderValue" targetTableId="vehicleTable" columnName="value" id="valueHeader" onClick="onClickAttributeHeader" focusId="focus_value_header" focusChangeBottom="focus_leasing_header" focusChangeTop="focus_name_header" focusChangeRight="focus_value_header">
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehicleTableHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
            </GuiElement>

            <!-- Vehicle table -->
            <GuiElement type="table" profile="ingameMenuGarageTable" position="1px -104px" rowTemplateName="vehicleRowTemplate" updateChildrenOverlayState="false" columnNames="vehicleName age ageIcon operatingHours operatingHoursIcon damage damageIcon leasing leasingIcon value valueIcon" id="vehicleTable" focusId="focus_vehicle_table" focusChangeLeft="focus_header" focusChangeRight="focus_header" focusChangeTop="focus_header" focusChangeBottom="focus_header" focusInit="onOpen">
                <GuiElement type="listItem" profile="ingameMenuVehicleRow" name="vehicleRowTemplate">
                    <GuiElement type="bitmap" profile="ingameMenuVehicleRowBackground">
                        <GuiElement type="text" profile="ingameMenuVehicleRowVehicleCell" name="vehicleName" onCreate="onDataBindVehicleName"/>

                        <GuiElement type="button" profile="ingameMenuVehicleRowAttributeCell" position="512px 0px" name="age" onCreate="onDataBindAge"/>
                        <GuiElement type="button" profile="ingameMenuVehicleRowAttributeCell" position="736px 0px" name="operatingHours" onCreate="onDataBindOperatingHours"/>
                        <GuiElement type="button" profile="ingameMenuVehicleRowAttributeCell" position="960px 0px" name="damage" onCreate="onDataBindDamage"/>
                        <GuiElement type="button" profile="ingameMenuVehicleRowAttributeCell" position="1184px 0px" name="leasing" onCreate="onDataBindLeasing"/>
                        <GuiElement type="button" profile="ingameMenuVehicleRowAttributeCell" position="1408px 0px" name="value" onCreate="onDataBindValue"/>
                    </GuiElement>
                </GuiElement>
            </GuiElement>

            <GuiElement type="bitmap" profile="verticalGlassListSliderBackground" size="28px 600px" position="-1px -104px">
                <GuiElement type="slider" profile="verticalGlassListSlider" size="16px 588px" dataElementId="vehicleTable" id="garageListSlider" />
            </GuiElement>
        </GuiElement>
    </GuiElement>
</GUI>
