<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="picture" profile="esportsScreenBgBsc" id="bgBsc"/>
    <GuiElement type="picture" profile="esportsScreenBgArena" id="bgArena"/>
    <GuiElement type="bitmap" profile="bgVignette"/>
    <GuiElement type="bitmap" profile="bgGlow" />

    <GuiElement type="bitmap" profile="uiElementContainerFullScreen">
        <GuiElement type="empty" profile="esportsScreenTitleContainer" id="bscContainer">
            <GuiElement type="text" profile="esportsScreenTitle" text="$l10n_ui_esports_baleStacking_title" />
            <GuiElement type="text" profile="esportsScreenDescription" text="$l10n_ui_esports_baleStacking_description" />
        </GuiElement>
        <GuiElement type="empty" profile="esportsScreenTitleContainer" id="arenaContainer">
            <GuiElement type="text" profile="esportsScreenTitle" text="$l10n_ui_esports_arena_title" />
            <GuiElement type="text" profile="esportsScreenDescription" text="$l10n_ui_esports_arena_description" />
        </GuiElement>

        <GuiElement type="boxLayout" profile="esportsScreenButtonsContainer">
            <GuiElement type="button" profile="esportsScreenButtonPlay" onClick="onClickJoinRandom" text="$l10n_ui_esports_button_play" id="buttonPlay" focusInit="onOpen">
                <GuiElement type="text" profile="esportsScreenButtonPlayDescription" text="$l10n_ui_esports_button_playDescription" />
                <GuiElement type="bitmap" profile="esportsScreenButtonPlaySelector" />
            </GuiElement>

            <GuiElement type="button" profile="esportsScreenButton" onClick="onClickOpenVideoScreen" text="$l10n_ui_esports_button_introduction" >
                <GuiElement type="bitmap" profile="esportsScreenButtonSelector" />
            </GuiElement>

            <GuiElement type="button" profile="esportsScreenButton" onClick="onClickStartTraining" text="$l10n_ui_esports_button_offline" >
                <GuiElement type="bitmap" profile="esportsScreenButtonSelector" />
            </GuiElement>

            <GuiElement type="button" profile="esportsScreenButton" onClick="onClickJoin" text="$l10n_ui_esports_button_customJoin" >
                <GuiElement type="bitmap" profile="esportsScreenButtonSelector" />
            </GuiElement>

            <GuiElement type="button" profile="esportsScreenButton" onClick="onClickStartMatch" text="$l10n_ui_esports_button_customCreate" >
                <GuiElement type="bitmap" profile="esportsScreenButtonSelector" />
            </GuiElement>
        </GuiElement>
    </GuiElement>

    <GuiElement type="flowLayout" profile="buttonBoxDockedOnScreen" >
        <GuiElement type="button" profile="buttonBack" text="$l10n_button_back" onClick="onClickBack" />
        <GuiElement type="button" profile="buttonActivate" text="$l10n_button_changeName" onClick="onClickChangeName" id="changeNameButton" />
        <GuiElement type="button" profile="buttonCancel" text="$l10n_button_blocklist" onClick="onClickOpenBlocklist" />
    </GuiElement>

    <GUIProfiles>
        <Profile name="esportsScreenBgBsc" extends="backgroundImage">
            <Value name="imageFilename" value="dataS/menu/esportsBg_bsc.png"/>
        </Profile>

        <Profile name="esportsScreenBgArena" extends="backgroundImage">
            <Value name="imageFilename" value="dataS/menu/esportsBg_arena.png"/>
        </Profile>

        <Profile name="esportsScreenButtonsContainer" extends="baseReference" with="anchorMiddleLeft">
            <Value name="size" value="640px 550px"/>
            <Value name="position" value="120px -100px"/>

            <Value name="imageColor" value="$preset_colorTransparent"/>

            <Value name="alignmentX" value="left"/>
            <Value name="alignmentY" value="top"/>
            <Value name="flowDirection" value="vertical"/>
            <Value name="autoValidateLayout" value="true"/>
        </Profile>

        <Profile name="esportsScreenTitleContainer" extends="baseReference" with="anchorMiddleLeft">
            <Value name="size" value="640px 200px"/>
            <Value name="position" value="120px 310px"/>
        </Profile>

        <Profile name="esportsScreenTitle" extends="textDefault" with="anchorTopLeft">
            <Value name="size" value="640px 50px"/>

            <Value name="textSize" value="35px"/>
            <Value name="textBold" value="true"/>
        </Profile>

        <Profile name="esportsScreenDescription" extends="textDefault" with="anchorBottomLeft">
            <Value name="size" value="640px 130px"/>

            <Value name="textSize" value="20px"/>
            <Value name="textVerticalAlignment" value="top"/>
            <Value name="textMaxNumLines" value="5"/>
        </Profile>

        <Profile name="esportsScreenButtonPlay" extends="buttonBase">
            <Value name="size" value="640px 120px"/>

            <Value name="imageColor" value="$preset_colorMainUI_50"/>
            <Value name="imageFocusedColor" value="$preset_colorMainUI"/>
            <Value name="imageHighlightedColor" value="$preset_colorMainUI"/>

            <Value name="textSize" value="35px"/>
            <Value name="textBold" value="true"/>
            <Value name="textMaxWidth" value="600px"/>
            <Value name="textUpperCase" value="true" />
            <Value name="textOffset" value="20px -20px"/>
            <Value name="textAlignment" value="left"/>
            <Value name="textVerticalAlignment" value="top"/>
        </Profile>

        <Profile name="esportsScreenButtonPlayDescription" extends="textDefault" with="anchorBottomLeft">
            <Value name="size" value="600px 80px"/>

            <Value name="textSize" value="20px"/>
            <Value name="textOffset" value="20px 0px"/>
        </Profile>

        <Profile name="esportsScreenButton" extends="buttonBase">
            <Value name="size" value="640px 60px"/>
            <Value name="margin" value="0 20px 0 0"/>

            <Value name="imageColor" value="0 0 0 0.5"/>
            <Value name="imageFocusedColor" value="0 0 0 0.8"/>
            <Value name="imageHighlightedColor" value="0 0 0 0.8"/>

            <Value name="textSize" value="26px"/>
            <Value name="textMaxWidth" value="600px"/>
            <Value name="textAlignment" value="left"/>
            <Value name="textUpperCase" value="true" />
            <Value name="textOffset" value="20px 0px"/>
            <Value name="textLayoutMode" value="resize"/>
        </Profile>

        <Profile name="esportsScreenButtonSelector" extends="baseReference" >
            <Value name="size" value="6px 60px"/>
            <Value name="position" value="-16px 0px"/>

            <Value name="imageColor" value="$preset_colorTransparent"/>
            <Value name="imageFocusedColor" value="$preset_colorMainUI"/>
        </Profile>

        <Profile name="esportsScreenButtonPlaySelector" extends="esportsScreenButtonSelector" >
            <Value name="size" value="6px 120px"/>
        </Profile>

    </GUIProfiles>
</GUI>