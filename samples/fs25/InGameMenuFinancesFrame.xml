            <Value name="textAlignment" value="right"/>
            <Value name="textUpperCase" value="true"/>
            <Value name="textSize" value="20px"/>
            <Value name="textColor" value="$preset_colorHeaderText"/>
            <Value name="position" value="0px 0px" />

            <Variant name="mobile">
                <Value name="position" value="0px 0px" />
                <Value name="textOffset" value="-30px 0px"/>
                <Value name="textSize" value="33px"/>
                <Value name="size" value="300px 100px"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuFinancesHeaderTodayMinusOne" extends="ingameMenuFinancesHeaderToday">
            <Value name="position" value="-200px 0px" />
            <Variant name="mobile" >
                <Value name="position" value="-300px 0px" />
            </Variant>
        </Profile>

        <Profile name="ingameMenuFinancesHeaderTodayMinusTwo" extends="ingameMenuFinancesHeaderToday">
            <Value name="position" value="-400px 0px" />
            <Variant name="mobile" >
                <Value name="position" value="-600px 0px" />
            </Variant>
        </Profile>

        <Profile name="ingameMenuFinancesHeaderTodayMinusThree" extends="ingameMenuFinancesHeaderToday">
            <Value name="position" value="-600px 0px" />
            <Variant name="mobile" >
                <Value name="position" value="-900px 0px" />
            </Variant>
        </Profile>
        <Profile name="ingameMenuFinancesHeaderTodayMinusFour" extends="ingameMenuFinancesHeaderToday">
            <Value name="position" value="-800px 0px" />
