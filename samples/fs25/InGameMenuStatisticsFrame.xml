<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuGameStats">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="bitmap" profile="ingameMenuStatisticsHeaderIcon" />
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" text="$l10n_ui_ingameMenuGameStats"/>
        </GuiElement>

        <GuiElement type="empty" profile="ingameMenuStatisticsContainer" id="statsContainer">
            <GuiElement type="bitmap" profile="topScrollClipper" name="topClipper" position="0 -98px"/>
            <GuiElement type="bitmap" profile="bottomScrollClipper" name="bottomClipper" position="0 -20px"/>
            <!-- Statistics table header -->
            <GuiElement type="bitmap" profile="ingameMenuStatisticsHeaderBox">
                <GuiElement type="text" profile="ingameMenuStatisticsHeaderName" text="$l10n_ui_statistic" />
                <GuiElement type="text" profile="ingameMenuStatisticsHeaderSession" text="$l10n_ui_session"/>
                <GuiElement type="text" profile="ingameMenuStatisticsHeaderTotal" text="$l10n_ui_total"/>
            </GuiElement>
            <GuiElement type="bitmap" profile="ingameMenuStatisticsHeaderBox2">
                <GuiElement type="text" profile="ingameMenuStatisticsHeaderName" text="$l10n_ui_statistic" />
                <GuiElement type="text" profile="ingameMenuStatisticsHeaderSession" text="$l10n_ui_session"/>
                <GuiElement type="text" profile="ingameMenuStatisticsHeaderTotal" text="$l10n_ui_total"/>
            </GuiElement>

            <!-- Statistics list -->
            <GuiElement type="smoothList" profile="ingameMenuStatisticsList" id="statisticsList1" listDataSource="self" listDelegate="self" startClipperElementName="topClipper" endClipperElementName="bottomClipper">
                <GuiElement type="listItem" profile="ingameMenuStatisticsListItem" name="rowTemplate" autoSelectChildren="false">
                    <GuiElement type="text" profile="ingameMenuStatisticsListItemName"    name="name" />
                    <GuiElement type="text" profile="ingameMenuStatisticsListItemSession" name="session" />
                    <GuiElement type="text" profile="ingameMenuStatisticsListItemTotal"   name="total" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="smoothList" profile="ingameMenuStatisticsList2" id="statisticsList2" listDataSource="self" listDelegate="self">
                <GuiElement type="listItem" profile="ingameMenuStatisticsListItem" name="rowTemplate" autoSelectChildren="false">
                    <GuiElement type="text" profile="ingameMenuStatisticsListItemName"    name="name" />
                    <GuiElement type="text" profile="ingameMenuStatisticsListItemSession" name="session" />
                    <GuiElement type="text" profile="ingameMenuStatisticsListItemTotal"   name="total" />
                </GuiElement>
            </GuiElement>

            <!-- Statistics slider -->
            <GuiElement type="threePartBitmap" profile="ingameMenuStatisticsSlider" >
                <GuiElement type="slider" profile="ingameMenuStatisticsSliderBar" dataElementId="statisticsList1" handleFocus="true" focusInit="onOpen"/>
            </GuiElement>
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="ingameMenuStatisticsHeaderIcon" extends="menuHeaderIcon">
            <Value name="size" value="64px 64px"/>
            <Value name="imageUVs" value="585px 0px 65px 65px"/>
        </Profile>

        <Profile name="ingameMenuStatisticsContainer" extends="ingameMenuSettingsBox">
            <Value name="size" value="680px 652px"/>

            <Variant name="mobile">
                <Value name="size" value="1768px 644px"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuStatisticsHeaderBox" with="ingameMenuHeaderBox">
            <Value name="size" value="680px 104px"/>

            <Variant name="mobile" with="ingameMenuHeaderBoxMobile">
                <Value name="position" value="0px 0px" />
                <Value name="imageColor" value="0 0 0 0" />
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsHeaderBox2" with="ingameMenuHeaderBox">
            <Value name="size" value="680px 104px"/>
            <Value name="position" value="720px 0px" />
            <Value name="visible" value="true" />

            <Variant name="mobile" with="ingameMenuHeaderBoxMobile">
                <Value name="visible" value="false" />
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsHeaderName" extends="textDefault" with="anchorBottomLeft">
            <Value name="textAlignment" value="left"/>
            <Value name="textOffset" value="30px 0px"/>
            <Value name="size" value="420px 104px"/>
            <Value name="textBold" value="true"/>
            <Value name="textSize" value="20px"/>
            <Value name="textUpperCase" value="true"/>
            <Value name="textColor" value="$preset_colorHeaderText"/>

            <Variant name="mobile" with="">
                <Value name="position" value="0px 0px" />
                <Value name="size" value="748px 104px"/>
                <Value name="textSize" value="33px"/>
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsHeaderTotal" extends="textDefault" with="anchorBottomRight">
            <Value name="size" value="160px 100px"/>
            <Value name="handleFocus" value="true"/>
            <Value name="textOffset" value="-20px 0px"/>
            <Value name="textAlignment" value="right"/>
            <Value name="textUpperCase" value="true"/>
            <Value name="position" value="0px 0px" />
            <Value name="textSize" value="20px"/>
            <Value name="textColor" value="$preset_colorHeaderText"/>

            <Variant name="mobile">
                <Value name="position" value="0px 0px" />
                <Value name="textAlignment" value="center"/>
                <Value name="size" value="400px 100px"/>
                <Value name="textSize" value="33px"/>
                <Value name="textOffset" value="0px 0px"/>
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsHeaderSession" extends="ingameMenuStatisticsHeaderTotal">
            <Value name="position" value="-160px 0px"/>
            <Variant name="mobile">
                <Value name="position" value="-400px 0px"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuStatisticsSlider" extends="verticalListSliderRightDocked">
            <Value name="visible" value="false" />

            <Variant name="mobile">
                <Value name="visible" value="true" />
                <Value name="size" value="12px 560px" />
                <Value name="position" value="28px -100px" />
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsSliderBar" extends="verticalListSliderBar">
            <Value name="size" value="6px 647px" />
            <Value name="hideParentWhenEmpty" value="false" />

            <Variant name="mobile">
                <Value name="size" value="6px 552px" />
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsList" extends="list" with="anchorTopLeft">
            <Value name="size" value="680px 640px"/>
            <Value name="position" value="0px -104px"/>
            <Value name="isHorizontalList" value="false"/>
            <Value name="handleFocus" value="false"/>

            <Variant name="mobile">
                <Value name="size" value="1768px 560px"/>
                <Value name="position" value="0px -100px"/>
                <Value name="supportsMouseScrolling" value="true" />
                <Value name="supportsTouchScrolling" value="true" />
                <Value name="itemizedScrollDelta" value="true" />
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsList2" extends="ingameMenuStatisticsList">
            <Value name="position" value="720px -104px"/>
            <Variant name="mobile">
                <Value name="visible" value="false" />
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsListItem" extends="listItem" with="alternating">
            <Value name="size" value="1400px 40px"/>
            <Value name="handleFocus" value="false"/>
            <Value name="allowSelected" value="false"/>
            <Value name="hideSelection" value="true"/>
            <Value name="imageColor" value="$preset_colorGlassMedium"/>
            <Value name="imageHighlightedColor" value="$preset_colorMainUI_50"/>
            <Value name="imageSelectedColor" value="$preset_colorMainUI_50"/>
            <Value name="imageFocusedColor" value="$preset_colorMainUI_50"/>

            <Variant name="mobile" with="">
                <Value name="size" value="1768px 70px"/>
                <Value name="imageColor" value="0 0 0 0"/>
                <Value name="imageFocusedColor" value="$preset_colorListRowAlternateBackground"/>
                <Value name="imageSelectedColor" value="$preset_colorListRowAlternateBackground"/>
                <Value name="alternateBackgroundColor" value="0 0 0 0" />
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsListItemName" extends="textDefault" >
            <Value name="size" value="420px 40px"/>
            <Value name="textSize" value="18px"/>
            <Value name="textBold" value="true"/>
            <Value name="textAlignment" value="left"/>
            <Value name="textColor" value="$preset_colorWhite"/>
            <Value name="textOffset" value="30px 0px"/>
            <Value name="textMaxWidth" value="380px"/>

            <Variant name="mobile">
                <Value name="size" value="900px 70px"/>
                <Value name="textSize" value="33px"/>
                <Value name="textMaxWidth" value="900px"/>
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsListItemTotal" extends="ingameMenuStatisticsListItemName" with="anchorBottomRight" >
            <Value name="position" value="0px 0px"/>
            <Value name="textOffset" value="-20px 0px"/>
            <Value name="textAlignment" value="right"/>
            <Value name="textBold" value="false"/>
            <Value name="textMaxWidth" value="120px"/>
            <Value name="size" value="160px 40px"/>

            <Variant name="mobile">
                <Value name="position" value="0px 0px"/>
                <Value name="textOffset" value="0px 0px"/>
                <Value name="size" value="400px 70px"/>
                <Value name="textMaxWidth" value="240px"/>
                <Value name="textAlignment" value="center"/>
            </Variant>
        </Profile>
        <Profile name="ingameMenuStatisticsListItemSession" extends="ingameMenuStatisticsListItemTotal">
            <Value name="position" value="-160px 0px"/>

            <Variant name="mobile">
                <Value name="position" value="-400px 0px"/>
            </Variant>
        </Profile>
    </GUIProfiles>
</GUI>
