<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="settingsDisplay">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="bitmap" profile="ingameMenuDisplaySettingsHeaderIcon" />
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" text="$l10n_ui_ingameMenuGameSettingsDisplay"/>
        </GuiElement>

        <!-- Layouted settings box -->
        <GuiElement type="bitmap" profile="mainMenuSettingsBox" id="settingsContainer">
            <GuiElement type="bitmap" profile="topScrollClipper" name="topClipper" />
            <GuiElement type="bitmap" profile="bottomScrollClipper" name="bottomClipper" />

            <GuiElement type="scrollingLayout" profile="ingameMenuSettingsLayout" id="boxLayout" topClipperElementName="topClipper" bottomClipperElementName="bottomClipper">
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickPerformanceClass" onCreate="onCreatePerformanceClass" id="performanceClassElement" focusInit="onOpen" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_hardwareProfile"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_hardwareProfile" />
                </GuiElement>
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickResolution" onCreate="onCreateResolution" id="resolutionElement" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_resolution"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_resolution" />
                </GuiElement>
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="checkedOption" profile="multiTextOptionSettings" onClick="onClickVSync" id="vSyncElement" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_vSync"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_vSync" />
                </GuiElement>
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickFullscreenMode" onCreate="onCreateFullscreenMode" id="fullscreenModeElement" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_windowMode"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_windowMode" />
                </GuiElement>
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickResolutionScale" onCreate="onCreateResolutionScale" id="resolutionScaleElement" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_resolutionScaling"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_resolutionScaling" />
                </GuiElement>
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickBrightness" onCreate="onCreateBrightness" id="brightnessElement" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_brightness"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_brightness" />
                </GuiElement>
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickFovY" onCreate="onCreateFovY" id="fovYElement" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_fovy"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_fovy" />
                </GuiElement>
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickUIScale" onCreate="onCreateUIScale" id="uiScaleElement" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_uiScale"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_uiScale" />
                </GuiElement>
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="checkedOption" profile="multiTextOptionSettings" onClick="onClickCameraBobbing" id="cameraBobbingElement" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_cameraBobbing"/>
                    <GuiElement type="text"   profile="multiTextOptionSettingsTooltip" text="$l10n_toolTip_cameraBobbing" />
                </GuiElement>
                <GuiElement type="empty" profile="settingsDisplayTextInputWrapper">
                    <GuiElement type="button" profile="ingameMenuSettingsButton" onClick="onHDRCalibration" text="$l10n_setting_hdr" id="hdrCalibrationButton"/>
                    <GuiElement type="text" profile="multiTextOptionSettingsTitle" text="$l10n_setting_hdr"/>
                </GuiElement>
            </GuiElement>

            <GuiElement type="threePartBitmap" profile="verticalListSliderRightDocked">
                <GuiElement type="slider" profile="verticalListSliderBar" dataElementId="boxLayout" handleFocus="false" />
            </GuiElement>
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="settingsDisplayTextInputWrapper" extends="baseReference">
            <Value name="size" value="1400px 48px"/>
            <Value name="margin" value="0 12px 0 12px"/>
            <Value name="focusFallthrough" value="true"/>
        </Profile>
    </GUIProfiles>
</GUI>
