<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="shopOthers">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="bitmap" profile="ingameMenuFinancesHeaderIcon" id="categoryHeaderIcon"/>
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" id="categoryHeaderText"/>
        </GuiElement>

        <GuiElement type="smoothList" profile="shopOtherList" id="otherShopsList" onClick="onOpenCategory" onDoubleClick="onOpenCategory" >
            <GuiElement type="listItem" profile="shopOtherItem" >
                <GuiElement type="bitmap" profile="shopOtherListItemImage" name="icon"/>
                <GuiElement type="text" profile="shopOthersListItemLabelText" name="title"/>
                <GuiElement type="bitmap" profile="listItemSelector"/>
            </GuiElement>
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="shopOtherList" extends="emptyPanel" with="anchorMiddleCenter">
            <Value name="handleFocus" value="true"/>
            <Value name="selectOnClick" value="true"/>
            <Value name="size" value="1400px 756px"/>

            <Value name="numLateralItems" value="4" />
            <Value name="listItemSpacing" value="9px" />
            <Value name="listItemLateralSpacing" value="9px" />

            <Variant name="mobile" >
                <Value name="size" value="1760px 644px"/>
                <Value name="position" value="0px 40px" />

                <Value name="listItemWidth" value="279px"/>
                <Value name="listItemHeight" value="312px"/>
                <Value name="listItemPadding" value="17px"/>
                <Value name="listItemSpacing" value="17px"/>

                <Value name="numLateralItems" value="2"/>
                <Value name="isHorizontalList" value="true"/>
            </Variant>
        </Profile>

        <Profile name="shopOtherItem" extends="emptyPanel" with="anchorBottomLeft">
            <Value name="handleFocus" value="false"/>
            <Value name="size" value="343px 533px"/>

            <Value name="imageColor" value="$preset_colorItemBgNormal"/>
            <Value name="imageFocusedColor" value="$preset_colorItemBgSelected"/>
            <Value name="imageSelectedColor" value="$preset_colorItemBgSelected"/>

            <Variant name="mobile">
                <Value name="size" value="279px 312px"/>
            </Variant>
        </Profile>

        <Profile name="shopOtherListItemImage" extends="emptyPanel" with="anchorTopCenter">
            <Value name="imageSize" value="512 512"/>
            <Value name="imageUVs" value="2px 2px 508px 508px"/>
            <Value name="imageColor" value="$preset_colorWhite"/>
            <Value name="size" value="200px 200px"/>
            <Value name="position" value="0px -50px"/>
        </Profile>

        <Profile name="shopOthersListItemLabelText" extends="textDefault" with="anchorBottomCenter">
            <Value name="size" value="290px 42px"/>
            <Value name="position" value="0px 80px"/>
            <Value name="textAlignment" value="center"/>
            <Value name="textVerticalAlignment" value="middle"/>
            <Value name="textSize" value="20px"/>
            <Value name="textMaxNumLines" value="2"/>
            <Value name="textColor" value="$preset_colorWhite_50"/>
            <Value name="textSelectedColor" value="$preset_colorMainUI"/>

            <Variant name="mobile" >
                <Value name="size" value="520px 42px"/>
                <Value name="position" value="0px 20px"/>
                <Value name="textBold" value="true"/>
                <Value name="textSize" value="40px"/>
                <Value name="textMaxNumLines" value="1"/>
                <Value name="textResizeWidth" value="560px"/>
                <Value name="textWrapWidth" value="1"/>
                <Value name="textColor" value="$preset_colorWhite"/>
                <Value name="textSelectedColor" value="$preset_colorWhite"/>
            </Variant>
        </Profile>
    </GUIProfiles>
</GUI>