<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="empty" profile="newLayer" />
    <GuiElement type="bitmap" profile="dialogFullscreenBg" id="dialogBg" />
    <GuiElement type="bitmap" profile="bgVignette"/>
    <GuiElement type="bitmap" profile="bgGlowDialog" />

    <GuiElement type="roundCorner" profile="sleepDialogBg" id="dialogElement">
        <GuiElement type="bitmap" profile="dialogHeaderDocked">
            <GuiElement type="text" profile="dialogHeaderText" text="" id="dialogTitleElement"/>
        </GuiElement>

        <GuiElement type="text" profile="sleepDialogText" text=""  id="dialogTextElement" />

        <GuiElement type="multiTextOption" profile="sleepDialogMultiTextOption" onClick="onClickTargetTime" id="targetTimeElement" focusInit="onOpen" />

        <GuiElement type="flowLayout" profile="buttonBoxDialogSleep">
            <GuiElement type="button" profile="buttonOK" text="$l10n_ui_inGameSleep" onClick="onYes" id="yesButton" />
            <GuiElement type="button" profile="buttonBack" text="$l10n_button_cancel" onClick="onNo" id="noButton" />
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="sleepDialogBg" extends="dialogBg">
            <Value name="size" value="630px 235px"/>

            <Variant name="mobile">
                <Value name="size" value="900px 380px" />
            </Variant>
        </Profile>
        <Profile name="buttonBoxDialogSleep" extends="buttonBoxDialog">

            <Variant name="mobile">
                <Value name="size" value="900px 200px" />
            </Variant>
        </Profile>

        <Profile name="sleepDialogText" extends="dialogText" with="anchorMiddleCenter">
            <Value name="position" value="0px 40px" />
            <Value name="textColor" value="$preset_colorWhite" />

            <Variant name="mobile" with="anchorTopCenter">
                <Value name="position" value="0px 0px" />
            </Variant>
        </Profile>

        <Profile name="sleepDialogMultiTextOption" extends="multiTextOption" with="anchorMiddleCenter">
            <Value name="position" value="0px -20px" />
        </Profile>
    </GUIProfiles>
</GUI>
