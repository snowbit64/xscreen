<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="empty" profile="newLayer" />
    <GuiElement type="bitmap" profile="dialogFullscreenBg" id="dialogBg" />

    <GuiElement type="roundCorner" profile="gameRateDialogBg" id="dialogElement">
        <GuiElement type="bitmap" profile="dialogHeaderDocked">
            <GuiElement type="text" profile="dialogHeaderText" text="$l10n_ui_rating" id="headerText" />
        </GuiElement>

        <GuiElement type="text" profile="dialogTitle" text="$l10n_ui_howDoYouLikeTheGame" />

        <GuiElement type="boxLayout" profile="gameRateDialogLayout" onLeave="onLayoutLeave" handleFocus="true" id="ratingLayout">
            <GuiElement type="button" profile="gameRateDialogStarButton" id="stars[1]" onHighlight="onStarHighlight" onHighlightRemove="onStarHighlightRemove" onFocus="onStarFocus" onClick="onStarClick" focusChangeLeft="" />
            <GuiElement type="button" profile="gameRateDialogStarButton" id="stars[2]" onHighlight="onStarHighlight" onHighlightRemove="onStarHighlightRemove" onFocus="onStarFocus" onClick="onStarClick" />
            <GuiElement type="button" profile="gameRateDialogStarButton" id="stars[3]" onHighlight="onStarHighlight" onHighlightRemove="onStarHighlightRemove" onFocus="onStarFocus" onClick="onStarClick" />
            <GuiElement type="button" profile="gameRateDialogStarButton" id="stars[4]" onHighlight="onStarHighlight" onHighlightRemove="onStarHighlightRemove" onFocus="onStarFocus" onClick="onStarClick" />
            <GuiElement type="button" profile="gameRateDialogStarButton" id="stars[5]" onHighlight="onStarHighlight" onHighlightRemove="onStarHighlightRemove" onFocus="onStarFocus" onClick="onStarClick" focusChangeRight="" />
        </GuiElement>

        <GuiElement type="flowLayout" profile="buttonBoxDialogGameRate">
            <GuiElement type="button" profile="buttonOK" text="$l10n_button_continue" onClick="onClickOk" id="okButton" />
            <GuiElement type="button" profile="buttonBack" text="$l10n_button_back" onClick="onClickBack" />
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="gameRateDialogBg" extends="dialogBg">
            <Value name="size" value="1200px 400px" />
        </Profile>
        <Profile name="buttonBoxDialogGameRate" extends="buttonBoxDialog">
            <Variant name="mobile">
                <Value name="size" value="1200px 200px" />
            </Variant>
        </Profile>

        <Profile name="gameRateDialogLayout" extends="baseReference" with="anchorMiddleCenter">
            <Value name="imageColor" value="$preset_colorTransparent" />
            <Value name="size" value="250px 50px" />
            <Value name="numFlows" value="6" />
            <Value name="flowDirection" value="horizontal" />
            <Value name="alignmentY" value="bottom" />

            <Variant name="mobile">
                <Value name="size" value="1000px 100px" />
                <Value name="position" value="0px 0px" />
            </Variant>
        </Profile>

        <Profile name="gameRateDialogStarButtonZero" extends="gameRateDialogStarButton">
            <Value name="size" value="0 50px" />
        </Profile>

        <Profile name="gameRateDialogStarButton" extends="baseReference" with="anchorTopLeft">
            <Value name="size" value="50px 50px" />
            <Value name="margin" value="0" />
            <Value name="iconSize" value="50px 50px" />
            <Value name="imageFilename" value="dataS/menu/modhubStar.png" />
            <Value name="imageUVs" value="0 0 1 1" />

            <Value name="imageColor" value="$preset_colorGlassMedium" />
            <Value name="imageFocusedColor" value="$preset_colorMainUI" />
            <Value name="imageHighlightedColor" value="$preset_colorBlue" />

            <Value name="handleFocus" value="true" />

            <Variant name="mobile">
                <Value name="imageFilename" value="dataS/menu/modhubStar.png" />
                <Value name="size" value="200px 200px" />
                <Value name="iconSize" value="200px 200px" />

                <Value name="imageColor" value="$preset_colorGlassMedium" />
                <Value name="imageFocusedColor" value="$preset_colorWhite" />
                <Value name="imageHighlightedColor" value="$preset_colorWhite" />
            </Variant>
        </Profile>

        <Profile name="gameRateDialogStarButtonActive" extends="gameRateDialogStarButton">
            <Value name="imageColor" value="$preset_colorMainUI" />

            <Variant name="mobile">
                <Value name="imageColor" value="$preset_colorWhite" />
            </Variant>
        </Profile>
    </GUIProfiles>
</GUI>
