<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="empty" profile="newLayer" />
    <GuiElement type="bitmap" profile="dialogFullscreenBg" id="dialogBg" />
    <GuiElement type="bitmap" profile="bgVignette"/>
    <GuiElement type="bitmap" profile="bgGlowDialog" />

    <GuiElement type="roundCorner" profile="colorDialogBg" id="dialogElement">
        <GuiElement type="bitmap" profile="dialogHeaderDocked">
            <GuiElement type="text" profile="dialogHeaderText" text="$l10n_ui_chooseColor" />
        </GuiElement>

        <GuiElement type="colorPickButton" profile="colorDialogColorButton" visible="false" onClick="onClickColorButton" onFocus="onFocusColorButton" onLeave="onLeaveColorButton" onHighlight="onFocusColorButton" onHighlightRemove="onLeaveColorButton" id="buttonTemplate" />

        <GuiElement type="boxLayout" profile="emptyPanel" id="colorButtonLayout" />

        <GuiElement type="text" profile="colorDialogColorName" id="colorName" />

        <GuiElement type="flowLayout" profile="buttonBoxDialog" id="buttonsPC">
            <GuiElement type="button" profile="buttonOK" text="$l10n_button_select" onClick="onClickOk" id="okButton" />
            <GuiElement type="button" profile="buttonBack" text="$l10n_button_back" onClick="onClickBack" id="backButton" />
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="colorDialogBg" extends="dialogBg">
            <Value name="size" value="498px 110px"/>
        </Profile>

        <Profile name="colorDialogColorButton" extends="wideButton" with="anchorTopLeft">
            <Value name="fitToContent" value="false"/>
            <Value name="handleFocus" value="true"/>

            <Value name="size" value="48px 48px"/>
            <Value name="position" value="0"/>
            <Value name="iconSize" value="0"/>
            <Value name="margin" value="2px 2px 2px 2px" />

            <Value name="selectionFrameThickness" value="3px 3px" />
            <Value name="selectionFrameColor" value="$preset_colorMainUI" />
            <Value name="metallicImageUVs" value="544px 718px 48px 48px" />
        </Profile>

        <Profile name="colorDialogColorName" extends="textDefault" with="anchorBottomCenter">
            <Value name="position" value="0 30px" />
            <Value name="size" value="400px 20px" />
            <Value name="textSize" value="18px" />
            <Value name="textMaxWidth" value="400px" />
            <Value name="textAlignment" value="center" />
        </Profile>

        <Profile namme="colorDialogBoxLayout" extends="emptyPanel">
            <Value name="size" value="417px 52px" />
            <Value name="position" value="0 15px" />
            <Value name="anchors" value="0.5 0.5 0.5 0.5" />
            <Value name="alignmentY" value="top" />
            <Value name="fitFlowToElements" value="true" />
            <Value name="flowDirection" value="horizontal" />
            <Value name="handleFocus" value="false" />

        </Profile>
    </GUIProfiles>
</GUI>
