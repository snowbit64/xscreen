<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="empty" profile="newLayer" />
    <GuiElement type="bitmap" profile="dialogFullscreenBg" id="dialogBg" />
    <GuiElement type="bitmap" profile="bgVignette"/>
    <GuiElement type="bitmap" profile="bgGlowDialog" />

    <GuiElement type="roundCorner" profile="infoDialogBg" id="dialogElement">
        <GuiElement type="animation" profile="dialogLoading"  id="iconLoadingElement" />

        <GuiElement type="bitmap" profile="dialogCircle" id="dialogCircle">
            <GuiElement type="bitmap"    profile="dialogQuestion" id="iconQuestionElement"/>
            <GuiElement type="bitmap"    profile="dialogWarning"  id="iconWarningElement"/>
            <GuiElement type="bitmap"    profile="dialogKey"      id="iconKeyElement"/>
            <GuiElement type="bitmap"    profile="dialogInfo"     id="iconInfoElement"/>
        </GuiElement>

        <GuiElement type="text" profile="infoDialogText" text="text" id="dialogTextElement" />

        <GuiElement type="flowLayout" profile="buttonBoxDialog" id="buttonsPC" >
            <GuiElement type="button" profile="buttonOK" text="$l10n_button_ok" onClick="onClickOk" id="okButton" />
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="infoDialogBg" extends="dialogBg">

            <Variant name="mobile">
                <Value name="size" value="1400px 300px"/>
            </Variant>
        </Profile>

        <Profile name="infoDialogText" extends="dialogText">

            <Variant name="mobile">
                <Value name="textSize" value="40px"/>
                <Value name="position" value="0px -210px"/>
                <Value name="textMaxNumLines" value="7" />
            </Variant>
        </Profile>
    </GUIProfiles>
</GUI>
