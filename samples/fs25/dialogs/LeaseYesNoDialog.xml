<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="empty" profile="newLayer" />
    <GuiElement type="bitmap" profile="dialogFullscreenBg" id="dialogBg" />
    <GuiElement type="bitmap" profile="bgVignette"/>
    <GuiElement type="bitmap" profile="bgGlowDialog" />

    <GuiElement type="roundCorner" profile="leaseDialogBg" id="dialogElement" >
        <GuiElement type="animation" profile="dialogLoading"  id="iconLoadingElement" visible="false" />

        <GuiElement type="bitmap" profile="leaseDialogCircle" id="dialogCircle">
            <GuiElement type="bitmap"    profile="dialogQuestion" id="iconQuestionElement" visible="false"/>
        </GuiElement>

        <GuiElement type="text" profile="leaseDialogKey" position="-45px -140px" text="$l10n_shop_costsBase:" />
        <GuiElement type="text" profile="leaseDialogValue" position="120px -140px" id="costsBaseValue" format="accounting" />
        <GuiElement type="text" profile="leaseDialogKey" position="-45px -160px" text="$l10n_shop_costsPerDay:" />
        <GuiElement type="text" profile="leaseDialogValue" position="120px -160px" id="costsPerDayValue" format="accounting" />
        <GuiElement type="text" profile="leaseDialogKey" position="-45px -180px" text="$l10n_shop_costsPerOperatingHour:" />
        <GuiElement type="text" profile="leaseDialogValue" position="120px -180px" id="costsPerOperatingHourValue" format="accounting" />

        <GuiElement type="text" profile="dialogTitle"         text="" id="dialogTitleElement" />
        <GuiElement type="text" profile="dialogTextWithTitle" text=""  id="dialogTextElement" position="0px -220px" />

        <GuiElement type="flowLayout" profile="buttonBoxDialog">
            <GuiElement type="button" profile="buttonYes" text="$l10n_button_yes" onClick="onYes" id="yesButton" />
            <GuiElement type="button" profile="buttonNo" text="$l10n_button_no" onClick="onNo" id="noButton" />
        </GuiElement>
    </GuiElement>

    <GUIProfiles>
        <Profile name="leaseDialogBg" extends="dialogBg">
            <Value name="size" value="630px 235px"/>

            <Variant name="mobile">
                <Value name="size" value="1000px 380px"/>
            </Variant>
        </Profile>

        <Profile name="leaseDialogCircle" extends="dialogCircle">

            <Variant name="mobile">
                <Value name="position" value="0px -20px"/>
            </Variant>
        </Profile>

        <Profile name="leaseDialogKey" extends="dialogText" with="anchorTopCenter">
            <Value name="size" value="240px 20px" />
            <Value name="position" value="0 0" />
            <Value name="textAlignment" value="left" />
            <Value name="textUpperCase" value="true"/>
            <Value name="textSize" value="14px"/>

            <Variant name="mobile">
                <Value name="textSize" value="24px"/>
            </Variant>
        </Profile>

        <Profile name="leaseDialogValue" extends="dialogText" with="anchorTopCenter">
            <Value name="size" value="90px 20px" />
            <Value name="position" value="0 0" />
            <Value name="textAlignment" value="right" />
            <Value name="textSize" value="14px"/>

            <Variant name="mobile">
                <Value name="textSize" value="24px"/>
            </Variant>
        </Profile>
    </GUIProfiles>
</GUI>
