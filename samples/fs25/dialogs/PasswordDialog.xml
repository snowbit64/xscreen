<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="empty" profile="newLayer" />
    <GuiElement type="bitmap" profile="dialogFullscreenBg" id="dialogBg" />
    <GuiElement type="bitmap" profile="bgVignette"/>
    <GuiElement type="bitmap" profile="bgGlowDialog" />

    <GuiElement type="roundCorner" profile="passwordDialogBg" id="dialogElement">
        <GuiElement type="text" profile="passwordDialogText" text="$l10n_ui_enterPassword" id="dialogTextElement" />

        <!-- TextInputElement with isPassword=true in profile: -->
        <GuiElement type="textInput" profile="passwordDialogTextInput" id="textElement" onEnterPressed="onEnterPressed" onEscPressed="onEscPressed" onFocus="onInputFocus" onLeave="onInputLeave" imeKeyboardType="password" imeTitle="$l10n_ui_password" imeDescription="$l10n_ui_password" imePlaceholder="$l10n_ui_password" enterWhenClickOutside="false" />

        <GuiElement type="flowLayout" profile="buttonBoxDialog" id="buttonsPC" >
            <GuiElement type="button" profile="buttonOK" text="$l10n_button_start" onClick="onClickOk" id="yesButton" />
            <GuiElement type="button" profile="buttonBack" text="$l10n_button_back"  onClick="onClickBack" id="noButton" />
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="passwordDialogBg" extends="dialogBg">
            <Value name="size" value="490px 200px"/>

            <Variant name="mobile">
                <Value name="size" value="900px 250px"/>
            </Variant>
        </Profile>

        <Profile name="passwordDialogText" extends="dialogText">
            <Value name="position" value="0px -42px"/>
            <Value name="textSize" value="15px"/>
            <Value name="textWrapWidth" value="370px"/>

            <Variant name="mobile">
                <Value name="position" value="0px -30px"/>
                <Value name="size" value="510px 30px"/>
                <Value name="textSize" value="35px" />
            </Variant>
        </Profile>

        <Profile name="passwordDialogTextInput" extends="dialogTextInput">
            <Value name="isPassword" value="true"/>
            <Value name="maxCharacters" value="16"/>

            <Variant name="mobile">
                <Value name="size" value="600px 105px"/>
                <Value name="textSize" value="35px"/>
                <Value name="cursorSize" value="2px 35px"/>
            </Variant>
        </Profile>
    </GUIProfiles>
</GUI>
