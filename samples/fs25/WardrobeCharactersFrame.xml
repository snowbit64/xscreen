<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="wardrobeCharacters">
    <GuiElement type="empty" profile="wardrobeFrame">

        <GuiElement type="text" profile="wardrobeOnlinePresenceNameText" id="nicknameElement" text="NAME: LALALALA" />

        <GuiElement type="text" profile="wardrobeFrameTitle" id="title" />

        <GuiElement type="empty" profile="wardrobeListFrame" position="0 -25px" size="590px 790px" >
            <GuiElement type="smoothList" profile="wardrobeCharacterList" id="itemList" onClick="onClickSelect" onDoubleClick="onClickSelect" focusInit="onOpen">
                <GuiElement type="listItem" profile="wardrobeCharacterListItem">
                    <GuiElement type="bitmap" profile="wardrobeCharacterIcon" name="icon" />

                    <GuiElement type="bitmap" profile="wardrobeItemSelection" name="selected">
                        <GuiElement type="bitmap" profile="wardrobeItemSelectionTick" />
                    </GuiElement>

                    <GuiElement type="bitmap" profile="listItemSelector"/>
                </GuiElement>
            </GuiElement>
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="wardrobeOnlinePresenceNameText" extends="textDefault" with="anchorTopRight">
            <Value name="text2Size" value="20px"/>
            <Value name="textSize" value="20px"/>
            <Value name="textBold" value="true"/>
            <Value name="text2Bold" value="true"/>
            <Value name="text2Color" value="0 0 0 1"/>
            <Value name="text2Offset" value="-1px -1px"/>
            <Value name="textAlignment" value="right"/>
            <Value name="position" value="-50px -50px"/>
            <Value name="textAutoWidth" value="true"/>
        </Profile>

        <Profile name="wardrobeCharacterList" extends="list">
            <Value name="position" value="0 0" />
            <Value name="size" value="590px 790px" />
            <Value name="isHorizontalList" value="false" />

            <Value name="listItemSpacing" value="10px"/>
            <Value name="listItemLateralSpacing" value="10px"/>
            <Value name="numLateralItems" value="3" />
        </Profile>

        <Profile name="wardrobeCharacterListItem" extends="listItem">
            <Value name="size" value="190px 190px" />

            <Value name="imageColor" value="$preset_colorItemBgNormal"/>
            <Value name="imageFocusedColor" value="$preset_colorItemBgSelected"/>
            <Value name="imageSelectedColor" value="$preset_colorItemBgSelected"/>
        </Profile>

        <Profile name="wardrobeCharacterIcon" extends="baseReference" with="anchorMiddleCenter">
            <Value name="size" value="190px 190px" />
        </Profile>
    </GUIProfiles>
</GUI>
