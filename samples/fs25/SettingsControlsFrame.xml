<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="settingsControls">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Page header, includes context message -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="button" profile="ingameMenuSettingsControlsHeaderHiddenButton" onClick="onClickKeyboardHeader" id="keyboardHiddenButton" handleFocus="false">
                <GuiElement type="text" profile="ingameMenuFrameHeaderText" text="$l10n_ui_inGameMenuControlsKeyboard" id="keyboardHeaderText"/>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuSettingsControlsHeaderHiddenButton" position="630px 0px" onClick="onClickGamepadHeader" id="gamepadHiddenButton" handleFocus="false">
                <GuiElement type="text" profile="ingameMenuFrameHeaderText" text="$l10n_ui_inGameMenuControlsController" id="gamepadHeaderText"/>
            </GuiElement>
        </GuiElement>

        <!-- Paging element used to switch between device tables -->
        <GuiElement type="paging" profile="ingameMenuSettingsBox" id="pagingElement">
            <!-- Controls binding tables for keyboard/mouse -->
            <GuiElement type="bitmap" profile="settingsControlsPage" id="keyboardMousePage">
                <GuiElement type="boxLayout" profile="settingsControlsTableHeaderBox">
                    <GuiElement type="tableHeader" profile="settingsControlsTableActionHeader" text="$l10n_ui_action"/>
                    <GuiElement type="tableHeader" profile="settingsControlsTableKeyboardHeader" position="515px 0px" text="$l10n_ui_key1" />
                    <GuiElement type="tableHeader" profile="settingsControlsTableKeyboardHeader" position="810px 0px" text="$l10n_ui_key2" />
                    <GuiElement type="tableHeader" profile="settingsControlsTableKeyboardHeader" position="1105px 0px" text="$l10n_ui_mouse"/>
                </GuiElement>


                <GuiElement type="smoothList" profile="settingsControlsTable" position="0 -104px" id="keyboardMouseTable" listSectionHeader="section">
                    <GuiElement type="listItem" profile="settingsControlsTableRow">
                        <GuiElement type="bitmap" profile="settingsControlsTableActionNameCell" handleFocus="false" >
                            <GuiElement type="text" profile="settingsControlsTableActionText" name="action"/>
                        </GuiElement>
                        <GuiElement type="button" profile="settingsControlsTableBindingCell" position="515px 0px" onClick="onClickKey1">
                            <GuiElement type="text" profile="settingsControlsTableText" name="key1"/>
                        </GuiElement>
                        <GuiElement type="button" profile="settingsControlsTableBindingCell" position="810px 0px" onClick="onClickKey2" >
                            <GuiElement type="text" profile="settingsControlsTableText" name="key2"/>
                        </GuiElement>
                        <GuiElement type="button" profile="settingsControlsTableBindingCell" position="1105px 0px" onClick="onClickMouse" >
                            <GuiElement type="text" profile="settingsControlsTableText" name="mouseButton"/>
                        </GuiElement>
                    </GuiElement>

                    <GuiElement type="listItem" profile="settingsControlsTableSectionHeader" name="section">
                        <GuiElement type="text" profile="settingsControlsTableSectionHeaderTitle" text="Help Line Title" name="title"/>
                    </GuiElement>
                </GuiElement>

                <GuiElement type="threePartBitmap" profile="verticalListSliderRightDocked" size="12px 652px" position="28px -104px" >
                    <GuiElement type="slider" profile="verticalListSliderBar" dataElementId="keyboardMouseTable" handleFocus="false" size="6px 644px" />
                </GuiElement>
            </GuiElement>

            <!-- Controls binding tables for gamepads / controllers -->
            <GuiElement type="bitmap" profile="settingsControlsPage" id="gamepadPage">
                <GuiElement type="boxLayout" profile="settingsControlsTableHeaderBox">
                    <GuiElement type="tableHeader" profile="settingsControlsTableActionHeader" text="$l10n_ui_action"/>
                    <GuiElement type="tableHeader" profile="settingsControlsTableGamepadHeader" position="515px 0px" text="$l10n_ui_gamepad"/>
                    <GuiElement type="tableHeader" profile="settingsControlsTableGamepadHeader" position="957.5px 0px" text="$l10n_ui_gamepad"/>
                </GuiElement>

                <GuiElement type="smoothList" profile="settingsControlsTable" position="0 -104px" id="gamepadTable" listSectionHeader="section">
                    <GuiElement type="listItem" profile="settingsControlsTableRowGamepad">
                         <GuiElement type="bitmap" profile="settingsControlsTableActionNameCell" handleFocus="false">
                            <GuiElement type="text" profile="settingsControlsTableActionText" name="gamepadAction" id="gamepadActionText" />
                        </GuiElement>
                        <GuiElement type="button" profile="settingsControlsTableBindingGamepadCell" position="515px 0px" onClick="onClickGamepadButton1" >
                            <GuiElement type="text" profile="settingsControlsTableText" name="gamepadButton1" id="gamepadActionButton1" />
                        </GuiElement>
                        <GuiElement type="button" profile="settingsControlsTableBindingGamepadCell" position="957.5px 0px" onClick="onClickGamepadButton2" >
                            <GuiElement type="text" profile="settingsControlsTableText" name="gamepadButton2" id="gamepadActionButton2" />
                        </GuiElement>
                    </GuiElement>

                    <GuiElement type="listItem" profile="settingsControlsTableSectionHeader" name="section">
                        <GuiElement type="text" profile="settingsControlsTableSectionHeaderTitle" text="Help Line Title" name="title"/>
                    </GuiElement>
                </GuiElement>

                <GuiElement type="threePartBitmap" profile="verticalListSliderRightDocked" size="12px 652px" position="28px -104px">
                    <GuiElement type="slider" profile="verticalListSliderBar" dataElementId="gamepadTable" handleFocus="false" size="6px 644px" />
                </GuiElement>
            </GuiElement>
        </GuiElement>

        <GuiElement type="empty" profile="settingsControlsMessageBox">
            <GuiElement type="text" profile="settingsControlsMessageText" text="" id="controlsMessage"/>
            <GuiElement type="bitmap" profile="settingsControlsMessageWarningIcon" visible="false" id="controlsMessageWarningIcon"/>
        </GuiElement>

        <GuiElement type="text" profile="controllerSettingsAbuseText" text="$l10n_stadia_controller_disclaimer" id="disclaimerLabel" />
    </GuiElement>


    <GUIProfiles>
        <Profile name="ingameMenuSettingsControlsHeaderHiddenButton" extends="emptyPanel">
            <Value name="size" value="830px 64px"/>
        </Profile>

        <Profile name="settingsControlsPage" extends="ingameMenuSettingsBox">
            <Value name="hasFrame" value="false"/>
            <Value name="position" value="0"/>
            <Value name="size" value="1400px 756px"/>
        </Profile>

        <Profile name="settingsControlsTableHeaderBox" extends="emptyPanel" with="anchorTopLeft">
            <Value name="size" value="1400px 104px"/>
            <Value name="alignmentX" value="left"/>
            <Value name="alignmentY" value="bottom"/>
            <Value name="imageColor" value="$preset_colorListHeaderBackground"/>
            <Value name="flowDirection" value="horizontal"/>
            <Value name="wrapAround" value="true"/>
            <Value name="lateralFlowSize" value="104px"/>
            <Value name="fitToElements" value="true"/>
            <Value name="autoValidateLayout" value="true"/>
            <Value name="hasFrame" value="false"/>

            <Variant name="mobile">
                <Value name="size" value="1768px 100px" />
                <Value name="position" value="0px 50px" />
            </Variant>
        </Profile>

        <Profile name="settingsControlsTableHeader" extends="wideButton" with="anchorBottomLeft">
            <Value name="margin" value="0 0 0 0" />
            <Value name="position" value="0"/>
            <Value name="size" value="163.33px 104px"/>

            <Value name="allowSortingAsc" value="false"/>
            <Value name="allowSortingDesc" value="false"/>

            <Value name="fitToContent" value="false"/>
            <Value name="handleFocus" value="false" />

            <Value name="iconSize" value="0"/>
            <Value name="iconTextOffset" value="0"/>
            <Value name="iconUVs" value="0 0 1 1"/>
            <Value name="iconColor" value="1 1 1 1"/>
            <Value name="iconFocusedColor" value="1 1 1 1"/>

            <Value name="imageColor" value="$preset_colorTransparent"/>

            <Value name="textUpper" value="true"/>
            <Value name="textAlignment" value="center"/>
            <Value name="textSize" value="20px" />
            <Value name="textVerticalAlignment" value="middle"/>

            <Variant name="mobile">
                <Value name="size" value="299px 100px"/>
                <Value name="iconSize" value="70px 70px"/>
            </Variant>
        </Profile>

        <Profile name="settingsControlsTableActionHeader" extends="settingsControlsTableHeader">
            <Value name="textAlignment" value="left"/>
            <Value name="textOffset" value="30px 0px"/>
            <Value name="size" value="515px 104px"/>
        </Profile>

        <Profile name="settingsControlsTableKeyboardHeader" extends="settingsControlsTableHeader">
            <Value name="size" value="295px 104px"/>
        </Profile>

        <Profile name="settingsControlsTable" extends="settingsControlsPage" with="anchorTopLeft">
            <Value name="size" value="1400px 652px" />
            <Value name="updateChildrenOverlayState" value="false"/>

            <Value name="itemsPerCol" value="16"/>
            <Value name="maxNumItems" value="16"/>

            <Value name="listItemHeight" value="40.75px"/>
            <Value name="listItemWidth" value="1400px"/>
        </Profile>

        <Profile name="settingsControlsTableRow" extends="emptyPanel" with="alternating">
            <Value name="updateChildrenOverlayState" value="false"/>
            <Value name="size" value="1400px 40.75px"/>

            <Value name="imageColor" value="$preset_colorListRowBackground"/>
        </Profile>

        <Profile name="settingsControlsTableActionNameCell" extends="emptyPanel">
            <Value name="handleFocus" value="true"/>
            <Value name="size" value="515px 40.75px"/>
            <Value name="textMaxWidth" value="500px" />
        </Profile>

        <Profile name="settingsControlsTableActionText" extends="settingsControlsTableText" with="anchorBottomLeft">
            <Value name="textAlignment" value="left"/>
            <Value name="textBold" value="true"/>
            <Value name="textUpperCase" value="false"/>
            <Value name="textOffset" value="30px 0px"/>
            <Value name="textMaxWidth" value="480px"/>
        </Profile>

        <Profile name="settingsControlsTableBindingCell" extends="settingsControlsTableActionNameCell">
            <Value name="size" value="295px 40.75px"/>
            <Value name="imageHighlightedColor" value="$preset_colorMainUI_50"/>
            <Value name="imageFocusedColor" value="$preset_colorMainUI"/>
        </Profile>

        <Profile name="settingsControlsTableText" extends="textDefault" with="anchorBottomCenter">
            <Value name="size" value="0 40.75px"/>
            <Value name="textAutoWidth" value="true"/>
            <Value name="textSize" value="18px"/>
            <Value name="textBold" value="false"/>
            <Value name="textAlignment" value="center"/>
            <Value name="textVerticalAlignment" value="middle"/>
            <Value name="textUpperCase" value="true"/>
            <Value name="textColor" value="$preset_colorWhite"/>
            <Value name="textFocusedColor" value="$preset_colorWhite"/>
            <Value name="textSelectedColor" value="$preset_colorWhite"/>
            <Value name="textHighlightedColor" value="$preset_colorWhite"/>

            <Value name="iconSize" value="0"/>
            <Value name="iconTextOffset" value="0"/>
            <Value name="textMaxWidth" value="340px"/>
        </Profile>

        <Profile name="settingsControlsTableSectionHeader" extends="listItem">
            <Value name="size" value="1400px 40.75px"/>
            <Value name="imageColor" value="$preset_colorListHeaderBackground" />
        </Profile>

        <Profile name="settingsControlsTableSectionHeaderTitle" extends="textDefault">
            <Value name="size" value="1300px 40.75px" />
            <Value name="textVerticalAlignment" value="middle"/>
            <Value name="textBold" value="true"/>
            <Value name="textOffset" value="30px 0px"/>
            <Value name="textFocusedOffset" value="30px 0px"/>
            <Value name="textSize" value="20px"/>
            <Value name="textUpperCase" value="true"/>
            <Value name="textColor" value="$preset_colorHeaderText"/>
        </Profile>

        <Profile name="settingsControlsTableGamepadHeader" extends="settingsControlsTableHeader">
            <Value name="size" value="442.5px 104px"/>
        </Profile>

        <Profile name="settingsControlsTableRowGamepad" extends="settingsControlsTableRow">
            <Value name="updateChildrenOverlayState" value="true"/>

            <Value name="imageColor" value="$preset_colorListRowBackground"/>
            <Value name="imageFocusedColor" value="$preset_colorFocusBackgroundGradient"/>
            <Value name="imageSelectedColor" value="$preset_colorFocusBackgroundGradient"/>
        </Profile>

        <Profile name="settingsControlsTableBindingGamepadCell" extends="settingsControlsTableBindingCell">
            <Value name="size" value="442.5px 40.75px"/>
        </Profile>

        <Profile name="settingsControlsMessageBox" extends="emptyPanel" with="anchorBottomRight">
            <Value name="size" value="600px 64px" />
            <Value name="position" value="0 -64px" />
        </Profile>

        <Profile name="settingsControlsMessageText" extends="textDefault" with="anchorMiddleRight">
            <Value name="textColor" value="$preset_colorWhite"/>
            <Value name="textMaxNumLines" value="2"/>
            <Value name="textAlignment" value="right"/>
            <Value name="size" value="600px 64px"/>
            <Value name="textSize" value="18px"/>
            <Value name="position" value="-40px 0"/>
        </Profile>

        <Profile name="settingsControlsMessageWarningIcon" extends="baseReference" with="anchorMiddleRight">
            <Value name="size" value="36px 36px"/>
            <Value name="imageColor" value="$preset_colorMainUI"/>
            <Value name="imageUVs" value="966px 102px 36px 36px"/>
        </Profile>
    </GUIProfiles>
</GUI>