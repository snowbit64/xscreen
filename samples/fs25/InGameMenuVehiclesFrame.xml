        </Profile>

        <Profile name="ingameMenuVehiclesHeaderValue" extends="textDefault" with="anchorBottomRight">
            <Value name="size" value="200px 100px"/>
            <Value name="handleFocus" value="true"/>
            <Value name="textOffset" value="0px 0px"/>
            <Value name="textAlignment" value="center"/>
            <Value name="position" value="0px 0px" />
            <Value name="imageColor" value="0 0 0 0"/>
            <Value name="iconFilename" value="g_baseUIFilename"/>
