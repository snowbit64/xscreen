            <Value name="position" value="-800px 0px"/>

            <Variant name="mobile">
                <Value name="position" value="-600px 0px"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesListItemHours" extends="ingameMenuVehiclesListItemValue">
            <Value name="position" value="-600px 0px"/>

            <Variant name="mobile">
                <Value name="position" value="-300px 0px"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesListItemLeasing" extends="ingameMenuVehiclesListItemValue">
