        <Profile name="ingameMenuVehiclesHeaderHours" extends="ingameMenuVehiclesHeaderValue">
            <Value name="iconUVs" value="96px 816px 96px 96px"/>
            <Value name="position" value="-600px 0px"/>

            <Variant name="mobile">
                <Value name="position" value="-300px 0px"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesHeaderDamage" extends="ingameMenuVehiclesHeaderValue">
            <Value name="iconUVs" value="384px 816px 96px 96px"/>
            <Value name="position" value="-400px 0px"/>
            <Variant name="mobile">
                <Value name="visible" value="false"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesHeaderLeasing" extends="ingameMenuVehiclesHeaderValue">
            <Value name="iconUVs" value="288px 816px 96px 96px"/>
            <Value name="position" value="-200px 0px"/>

            <Variant name="mobile">
                <Value name="visible" value="false"/>
