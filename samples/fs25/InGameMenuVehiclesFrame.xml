            <Value name="iconColor" value="$preset_colorWhite"/>
            <Value name="iconFocusedColor" value="$preset_colorMainUI_50"/>
            <Value name="iconHighlightedColor" value="$preset_colorMainUI"/>
            <Value name="iconSelectedColor" value="$preset_colorMainUI_50"/>
            <Value name="iconDisabledColor" value="$preset_colorDisabled"/>

            <Variant name="console">
