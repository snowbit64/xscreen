<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="garageOverview">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderIcon" />
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" id="headerText" text="$l10n_ui_garageOverview"/>
        </GuiElement>

        <GuiElement type="empty" profile="ingameMenuVehiclesBox" id="mainBox">
            <GuiElement type="bitmap" profile="topScrollClipper" name="topClipper" position="0 -98px"/>
            <GuiElement type="bitmap" profile="bottomScrollClipper" name="bottomClipper" position="0 6px"/>

            <!-- Vehicle table header -->
            <GuiElement type="boxLayout" profile="ingameMenuVehiclesHeaderBox" id="headerBox">
                <GuiElement type="button" profile="ingameMenuVehiclesHeaderName" text="$l10n_ui_vehicle" onClick="onClickButtonSortByName" onCreate="onCreateButtonSortByName">
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderNameSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderNameSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="button" profile="ingameMenuVehiclesHeaderAge" onClick="onClickButtonSortByAge" onCreate="onCreateButtonSortByAge">
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="button" profile="ingameMenuVehiclesHeaderHours" onClick="onClickButtonSortByHours" onCreate="onCreateButtonSortByHours">
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="button" profile="ingameMenuVehiclesHeaderDamage" onClick="onClickButtonSortByDamage" onCreate="onCreateButtonSortByDamage">
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="button" profile="ingameMenuVehiclesHeaderLeasing" onClick="onClickButtonSortByLeasing" onCreate="onCreateButtonSortByLeasing">
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
                <GuiElement type="button" profile="ingameMenuVehiclesHeaderValue" onClick="onClickButtonSortByValue" onCreate="onCreateButtonSortByValue">
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortAscending" name="iconAscending"/>
                    <GuiElement type="bitmap" profile="ingameMenuVehiclesHeaderSortDescending" name="iconDescending"/>
                </GuiElement>
            </GuiElement>

            <!-- Vehicles list -->
            <GuiElement type="smoothList" profile="ingameMenuVehiclesList" id="vehiclesList" listDataSource="self" listDelegate="self"  startClipperElementName="topClipper" endClipperElementName="bottomClipper">
                <GuiElement type="listItem" profile="ingameMenuVehiclesListItem" name="rowTemplate" autoSelectChildren="false">
                    <GuiElement type="text" profile="ingameMenuVehiclesListItemName"    name="name" />
                    <GuiElement type="text" profile="ingameMenuVehiclesListItemAge"     name="age" />
                    <GuiElement type="text" profile="ingameMenuVehiclesListItemHours"   name="operatingHours" />
                    <GuiElement type="text" profile="ingameMenuVehiclesListItemDamage"  name="damage" />
                    <GuiElement type="text" profile="ingameMenuVehiclesListItemLeasing" name="leasing" />
                    <GuiElement type="text" profile="ingameMenuVehiclesListItemValue"   name="value" />
                </GuiElement>
            </GuiElement>

            <!-- Vehicles slider -->
            <GuiElement type="threePartBitmap" profile="ingameMenuVehiclesSlider" >
                <GuiElement type="slider" profile="ingameMenuVehiclesSliderBar" dataElementId="vehiclesList" />
            </GuiElement>
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="ingameMenuVehiclesHeaderIcon" extends="menuHeaderIcon">
            <Value name="size" value="64px 64px"/>
            <Value name="imageUVs" value="260px 0px 65px 65px"/>
        </Profile>

        <Profile name="ingameMenuVehiclesBox" with="ingameMenuBox">

            <Variant name="mobile" with="ingameMenuBoxMobile">
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesHeaderBox" with="ingameMenuHeaderBox">
            <Value name="flowDirection" value="horizontal" />
            <Value name="wrapAround" value="true"/>

            <Variant name="mobile" with="ingameMenuHeaderBoxMobile">
                <Value name="position" value="0px -100px" />
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesHeaderName" extends="textDefault" with="anchorBottomLeft">
            <Value name="textAlignment" value="left"/>
            <Value name="textOffset" value="30px 0px"/>
            <Value name="size" value="420px 104px"/>
            <Value name="textBold" value="true"/>
            <Value name="textSize" value="20px"/>
            <Value name="textUpperCase" value="true"/>
            <Value name="textColor" value="$preset_colorWhite"/>
            <Value name="textFocusedColor" value="$preset_colorMainUI_50"/>
            <Value name="textHighlightedColor" value="$preset_colorMainUI"/>
            <Value name="textSelectedColor" value="$preset_colorMainUI_50"/>
            <Value name="textDisabledColor" value="$preset_colorDisabled"/>
            <Value name="imageColor" value="0 0 0 0"/>

            <Variant name="mobile" with="">
                <Value name="position" value="10px 0px" />
                <Value name="size" value="868px 104px"/>
                <Value name="textSize" value="33px"/>
                <Value name="textColor" value="$preset_colorWhite_25"/>
                <Value name="textFocusedColor" value="$preset_colorWhite"/>
                <Value name="textHighlightedColor" value="$preset_colorWhite"/>
                <Value name="textSelectedColor" value="$preset_colorWhite"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesHeaderNameSortAscending" extends="baseReference" with="anchorMiddleLeft">
            <Value name="imageColor" value="$preset_colorWhite"/>
            <Value name="imageUVs" value="678px 390px 36px 36px"/>
            <Value name="imageRotation" value="180"/>
            <Value name="size" value="12px 12px"/>
            <Value name="position" value="10px 0px"/>

            <Variant name="mobile">
                <Value name="position" value="0px 0px" />
                <Value name="size" value="20px 20px"/>
                <Value name="imageColor" value="$preset_colorWhite_25"/>
                <Value name="imageFocusedColor" value="$preset_colorWhite"/>
                <Value name="imageHighlightedColor" value="$preset_colorWhite"/>
                <Value name="imageSelectedColor" value="$preset_colorWhite"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesHeaderNameSortDescending" extends="ingameMenuVehiclesHeaderNameSortAscending">
            <Value name="imageRotation" value="0"/>
        </Profile>

        <Profile name="ingameMenuVehiclesHeaderAge" extends="ingameMenuVehiclesHeaderValue">
            <Value name="iconUVs" value="0px 816px 96px 96px"/>
            <Value name="position" value="-800px 0px"/>

            <Variant name="mobile">
                <Value name="position" value="-600px 0px"/>
                <Value name="iconColor" value="$preset_colorWhite_25"/>
                <Value name="iconFocusedColor" value="$preset_colorWhite"/>
                <Value name="iconHighlightedColor" value="$preset_colorWhite"/>
                <Value name="iconSelectedColor" value="$preset_colorWhite"/>
            </Variant>
        </Profile>

        <Profile name="ingameMenuVehiclesHeaderSortAscending" extends="baseReference" with="anchorMiddleLeft">
            <Value name="imageColor" value="$preset_colorWhite"/>
            <Value name="imageUVs" value="678px 390px 36px 36px"/>
            <Value name="imageRotation" value="-180"/>
