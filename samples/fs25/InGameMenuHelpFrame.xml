<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuHelpLine">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="bitmap" profile="ingameMenuHelpHeaderIcon" />
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" text="$l10n_ui_ingameMenuHelpLine"/>
        </GuiElement>

        <GuiElement type="empty" profile="helpContainer" id="helpContainer">
            <!-- Navigation Box -->
            <GuiElement type="empty" profile="ingameMenuHelpNavigationBox">

                <GuiElement type="bitmap" profile="ingameMenuHelpTopScrollClipper" name="topClipper" position="0 2dp" />
                <GuiElement type="bitmap" profile="ingameMenuHelpBottomScrollClipper" name="bottomClipper" />

                <GuiElement type="smoothList" profile="ingameMenuHelpList" id="helpLineList" focusInit="onOpen" listSectionHeader="section" startClipperElementName="topClipper" endClipperElementName="bottomClipper">
                    <GuiElement type="listItem" profile="ingameMenuHelpListItem">
                        <GuiElement type="text" profile="helpLineListItemText" text="Help Line Title" name="title"/>
                    </GuiElement>

                    <GuiElement type="listItem" profile="ingameMenuHelpListCategory" name="section">
                        <GuiElement type="text" profile="ingameMenuHelpListCategoryTitle" text="Help Line Title" name="title"/>
                    </GuiElement>
                </GuiElement>

                <GuiElement type="threePartBitmap" profile="helpSlider">
                    <GuiElement type="slider" profile="helpSliderBar" dataElementId="helpLineList" handleFocus="false" />
                </GuiElement>
            </GuiElement>

            <!-- Content Box -->
            <GuiElement type="empty" profile="ingameMenuHelpContentBox">
                <GuiElement type="text" profile="helpLineTitle" id="helpLineTitleElement" />

                <GuiElement type="bitmap" profile="helpStartScrollClipper" name="topClipper" />
                <GuiElement type="bitmap" profile="helpEndScrollClipper" name="bottomClipper" />

                <GuiElement type="scrollingLayout" profile="helpLineContentBox" id="helpLineContentBox" topClipperElementName="topClipper" bottomClipperElementName="bottomClipper">
                    <GuiElement type="text"   profile="helpLineItemTitle"  id="helpLineContentItemTitle" />
                    <GuiElement type="flowLayout" profile="helpLineContentItem" id="helpLineContentItem">
                        <GuiElement type="bitmap" profile="helpLineImage" name="image" />
                        <GuiElement type="text"   profile="helpLineText"  name="text" />
                        <GuiElement type="text"   profile="helpLineTextFullWith"  name="textFullWidth"  />
                    </GuiElement>
                </GuiElement>

                <GuiElement type="threePartBitmap" profile="helpSlider">
                    <GuiElement type="slider" profile="helpSliderBar" dataElementId="helpLineContentBox" handleFocus="false" />
                </GuiElement>

            </GuiElement>
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="ingameMenuHelpTopScrollClipper" extends="topScrollClipper" with="anchorTopCenter">
            <Value name="position" value="0 -77dp" />
            <Value name="size" value="490px 2dp" />
        </Profile>
        <Profile name="ingameMenuHelpBottomScrollClipper" extends="ingameMenuHelpTopScrollClipper" with="anchorBottomCenter">
            <Value name="position" value="0 -2dp" />
        </Profile>

        <Profile name="ingameMenuHelpHeaderIcon" extends="menuHeaderIcon">
            <Value name="imageUVs" value="0px 65px 65px 65px"/>
        </Profile>

        <Profile name="helpContainer" extends="emptyPanel" >
            <Value name="size" value="1400px 756px" />
            <Value name="anchors" value="0 0 1 1" />

            <Variant name="mobile" with="anchorMiddleCenter">

                <Value name="anchors" value="0.5 0.5 0.5 0.5" />
                <Value name="position" value="0px 50px" />
                <Value name="size" value="1768px 650px" />
            </Variant>
        </Profile>

        <Profile name="ingameMenuHelpNavigationBox" extends="emptyPanel" with="anchorTopLeft">
            <Value name="size" value="426px 756px"/>

            <Variant name="mobile" >
                <Value name="size" value="530px 650px" />
                <Value name="hasFrame" value="false" />
            </Variant>
        </Profile>

        <Profile name="ingameMenuHelpList" extends="list" with="anchorTopLeft">
            <Value name="size" value="426px 756px"/>
            <Value name="isHorizontalList" value="false"/>

            <Value name="rowBackgroundProfile" value="ingameMenuHelpListItem"/>
            <Value name="rowBackgroundProfileAlternate" value="helpLineListItemAlternate"/>

            <Variant name="mobile" with="lightFrame">
                <Value name="position" value="0px 0px" />
                <Value name="size" value="530px 650px" />
                <Value name="listItemHeight" value="90px"/>
                <Value name="listItemWidth" value="530px"/>
                <Value name="itemsPerCol" value="5"/>
                <Value name="keepSelectedInView" value="true" />
                <Value name="supportsTouchScrolling" value="true" />
                <Value name="hasFrame" value="false" />
            </Variant>
        </Profile>

        <Profile name="ingameMenuHelpListItem" extends="listItem" with="alternating">
            <Value name="size" value="426px 42px"/>

            <Value name="imageColor" value="$preset_colorListRowBackground"/>
            <Value name="imageFocusedColor" value="$preset_colorFocusBackgroundGradient"/>
            <Value name="imageSelectedColor" value="$preset_colorFocusBackgroundGradient"/>

            <Variant name="mobile">
                <Value name="size" value="530px 90px" />
                <Value name="imageColor" value="0 0 0 0"/>
                <Value name="imageFocusedColor" value="$preset_colorListRowAlternateBackground"/>
                <Value name="imageSelectedColor" value="$preset_colorListRowAlternateBackground"/>
