                <Value name="textSize" value="33px"/>
            </Variant>
        </Profile>

        <Profile name="helpSlider" extends="verticalListSliderRightDocked">

            <Variant name="mobile" >
                <Value name="size" value="12px 650px" />
            </Variant>
        </Profile>
        <Profile name="helpSliderBar" extends="verticalListSliderBar">

