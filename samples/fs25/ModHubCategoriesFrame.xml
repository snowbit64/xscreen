<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="modHubCategories">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" position="0 0" id="headerText"/>

            <!-- Current balance display in header -->
            <GuiElement type="flowLayout" profile="shopMoneyBox">
                <GuiElement type="text" profile="shopBalance" text="$l10n_ui_usedDiscSpace:" />
                <GuiElement type="text" profile="shopMoney" id="spaceUsageLabel" />
            </GuiElement>
        </GuiElement>

        <GuiElement type="bitmap" profile="topScrollClipper" name="topClipper" />
        <GuiElement type="bitmap" profile="bottomScrollClipper" name="bottomClipper" />

        <GuiElement type="smoothList" profile="modHubCategoryList" id="categoryList" onClick="onActivateCategory" onDoubleClick="onActivateCategory" focusInit="onOpen" startClipperElementName="topClipper" endClipperElementName="bottomClipper" listDelegate="self" listDataSource="self">

            <GuiElement type="listItem" profile="modHubCategoryItem">
                <GuiElement type="empty" profile="modHubCategoryItemImagePanel">
                    <GuiElement type="bitmap" profile="modHubCategoryItemImage" name="image"/>
                </GuiElement>

                <GuiElement type="text" profile="modHubCategoryItemText" name="text"/>

                <GuiElement type="flowLayout" profile="modHubMarkerBox" name="markerBox">
                    <GuiElement type="bitmap" profile="modHubMarkerConflict" name="markerConflict" />
                    <GuiElement type="bitmap" profile="modHubMarkerUpdate" name="markerUpdate" />
                    <GuiElement type="bitmap" profile="modHubMarkerNew" name="markerNew" />
                </GuiElement>

                <GuiElement type="bitmap" profile="listItemSelector"/>
            </GuiElement>
        </GuiElement>

        <GuiElement type="threePartBitmap" profile="verticalListSliderRightDocked">
            <GuiElement type="slider" profile="verticalListSliderBar" dataElementId="categoryList" />
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="modHubCategoryList" extends="emptyPanel" with="anchorMiddleCenter">
            <Value name="handleFocus" value="true"/>
            <Value name="selectOnClick" value="true"/>
            <Value name="size" value="1400px 756px"/>

            <Value name="numLateralItems" value="7" />
            <Value name="listItemSpacing" value="9px" />
            <Value name="listItemLateralSpacing" value="9px" />

            <Variant name="mobile" >
                <Value name="size" value="1760px 644px"/>
                <Value name="position" value="0px 40px" />

                <Value name="listItemWidth" value="279px"/>
                <Value name="listItemHeight" value="312px"/>
                <Value name="listItemPadding" value="17px"/>
                <Value name="listItemSpacing" value="17px"/>

                <Value name="numLateralItems" value="2"/>
                <Value name="isHorizontalList" value="true"/>
            </Variant>
        </Profile>

        <Profile name="modHubCategoryItem" extends="emptyPanel" with="anchorBottomLeft">
            <Value name="handleFocus" value="false"/>
            <Value name="size" value="192px 246px"/>

            <Value name="imageColor" value="$preset_colorItemBgNormal"/>
            <Value name="imageFocusedColor" value="$preset_colorItemBgSelected"/>
            <Value name="imageSelectedColor" value="$preset_colorItemBgSelected"/>

            <Variant name="mobile">
                <Value name="size" value="279px 312px"/>
            </Variant>
        </Profile>

        <Profile name="modHubCategoryItemImage" extends="baseReference" with="anchorMiddleCenter">
            <Value name="position" value="0"/>
            <Value name="imageUVs" value="0 0 1 1"/>
            <Value name="size" value="160px 160px" />

            <Variant name="mobile" with="anchorTopCenter">
                <Value name="size" value="260px 260px"/>
                <Value name="position" value="0px 0px"/>
            </Variant>
        </Profile>

        <Profile name="modHubCategoryItemImagePanel" extends="emptyPanel" with="anchorTopCenter">
            <Value name="size" value="160px 160px"/>
            <Value name="position" value="0px -10px" />

            <Variant name="mobile">
                <Value name="size" value="215px 210px"/>
                <Value name="position" value="0px 0px" />
            </Variant>
        </Profile>

        <Profile name="modHubCategoryItemText" extends="textDefault" with="anchorTopCenter">
            <Value name="size" value="0 54px"/>

            <Value name="textMaxWidth" value="170px"/>
            <Value name="textSize" value="18px"/>
            <Value name="textAlignment" value="center"/>
            <Value name="textVerticalAlignment" value="middle"/>
            <Value name="textMaxNumLines" value="3"/>
            <Value name="position" value="0px -175px" />

            <Value name="textColor" value="$preset_colorWhite_50"/>
            <Value name="textSelectedColor" value="$preset_colorMainUI"/>

            <Variant name="mobile" with="anchorBottomCenter">
                <Value name="size" value="270px 64px"/>
                <Value name="textSize" value="33px"/>
                <Value name="textMaxWidth" value="250px"/>
                <Value name="position" value="0px 0px" />
                <Value name="textMaxNumLines" value="2"/>
                <Value name="textResizeLines" value="1"/>
                <Value name="textBold" value="false"/>
                <Value name="textResizeWidth" value="250px"/>
                <Value name="textColor" value="$preset_colorWhite"/>
                <Value name="textSelectedColor" value="$preset_colorWhite"/>
            </Variant>
        </Profile>
    </GUIProfiles>
</GUI>