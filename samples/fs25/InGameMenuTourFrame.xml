<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuTour">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="bitmap" profile="ingameMenuTourHeaderIcon" />
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" text="$l10n_ui_tour" id="headerText" />
        </GuiElement>

        <GuiElement type="empty" id="controlItem" profile="tourMenuItemControlsItem">
            <GuiElement type="inputGlyph" name="glyph" profile="tourMenuItemControlsGlyph" />
            <GuiElement type="text" name="text" profile="tourMenuItemControlsText" />
        </GuiElement>

        <GuiElement type="empty" profile="tourContentContainer">
            <GuiElement type="bitmap" profile="topScrollClipper" name="topClipper" />
            <GuiElement type="bitmap" profile="bottomScrollClipper" name="bottomClipper" />
            <GuiElement type="scrollingLayout" profile="tourMenuLayout" id="layout" topClipperElementName="topClipper" bottomClipperElementName="bottomClipper">
                <GuiElement type="bitmap" profile="tourMenuItem" id="contentItem">
                    <GuiElement type="text" profile="tourMenuItemText" name="text" />

                    <GuiElement type="boxLayout" profile="tourMenuItemControls" name="controls" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="threePartBitmap" profile="tourMenuSlider" id="slider">
                <GuiElement type="slider" profile="tourMenuSliderBar" dataElementId="layout" handleFocus="false" />
            </GuiElement>
        </GuiElement>

    </GuiElement>


    <GUIProfiles>
        <Profile name="ingameMenuTourHeaderIcon" extends="menuHeaderIcon">
            <Value name="imageUVs" value="0px 65px 65px 65px"/>
        </Profile>

        <Profile name="tourMenuItemControlsItem" extends="emptyPanel">
            <Value name="size" value="1340px 54px"/>

            <Value name="hasFrame" value="true"/>
            <Value name="frameThickness" value="0 1dp 0 0"/>
            <Value name="frameBottomColor" value="$preset_colorWhite"/>

            <Variant name="mobile">
                <Value name="size" value="1340px 70px"/>
                <Value name="hasFrame" value="false"/>
            </Variant>
        </Profile>

        <Profile name="tourMenuItemControlsGlyph" extends="baseReference" with="anchorMiddleLeft">
            <Value name="size" value="36px 36px"/>
            <Value name="glyphColor" value="$preset_colorWhite" />

            <Variant name="mobile" with="anchorMiddleRight">
                <Value name="size" value="45px 45px"/>
                <Value name="isLeftAligned" value="true" />
                <Value name="glyphColor" value="$preset_colorBlack" />
            </Variant>
        </Profile>

        <Profile name="tourMenuItemControlsText" extends="textDefault" with="anchorMiddleRight">
            <Value name="size" value="900px 40px"/>
            <Value name="textAutoWidth" value="false"/>
            <Value name="textAlignment" value="right"/>
            <Value name="textVerticalAlignment" value="middle"/>

            <Variant name="mobile">
                <Value name="position" value="-150px 0px"/>
                <Value name="textSize" value="28px"/>
            </Variant>
        </Profile>

        <Profile name="tourContentContainer" extends="emptyPanel" with="anchorTopCenter">
            <Value name="size" value="1400px 756px"/>

            <Variant name="mobile">
                <Value name="size" value="1400px 700px"/>
                <Value name="position" value="0px -140px"/>
            </Variant>
        </Profile>

        <Profile name="tourMenuLayout" extends="emptyPanel" with="anchorTopLeft">
            <Value name="size" value="1400px 756px"/>
            <Value name="imageColor" value="$preset_colorTransparent"/>
            <Value name="autoValidateLayout" value="false"/>

            <Variant name="mobile" with="anchorMiddleCenter">
                <Value name="size" value="1400px 700px"/>
                <Value name="supportsTouchScrolling" value="true" />
            </Variant>
        </Profile>

        <Profile name="tourMenuItem" extends="emptyPanel" with="anchorTopLeft">
            <Value name="size" value="1400px 756px"/>
            <Value name="position" value="0 0"/>
            <Value name="imageColor" value="$preset_colorListRowBackground" />

            <Variant name="mobile">
                <Value name="size" value="1400px 756px"/>
                <Value name="imageColor" value="0 0 0 0"/>
                <Value name="imageFocusedColor" value="$preset_colorListRowAlternateBackground"/>
                <Value name="imageSelectedColor" value="$preset_colorListRowAlternateBackground"/>
                <Value name="alternateBackgroundColor" value="0 0 0 0" />

                <Value name="margin" value="0 0 0 50px"/>
            </Variant>
        </Profile>

        <Profile name="tourMenuItemAlt" extends="tourMenuItem">
            <Value name="imageColor" value="$preset_colorListRowAlternateBackground" />
            <Variant name="mobile">
                <Value name="imageColor" value="0 0 0 0"/>
            </Variant>
        </Profile>

        <Profile name="tourMenuItemCurrent" extends="tourMenuItem">
            <Value name="imageColor" value="0.3140 0.8069 1.0000 0.3"/>
            <Variant name="mobile">
                <Value name="imageColor" value="0 0 0 0"/>
            </Variant>
        </Profile>

        <Profile name="tourMenuItemText" extends="textDefault" with="anchorTopLeft">
            <Value name="size" value="1340px 200px"/>
            <Value name="position" value="30px -30px"/>

            <Value name="textVerticalAlignment" value="top"/>
            <Value name="textSize" value="18px"/>
            <Value name="textBold" value="false"/>
            <Value name="textMaxWidth" value="1340px"/>
            <Value name="textMaxNumLines" value="100"/>
            <Value name="textColor" value="$preset_colorWhite"/>

            <Variant name="mobile">
                <Value name="textSize" value="28px"/>
            </Variant>
        </Profile>

        <Profile name="tourMenuItemControls" extends="emptyPanel" with="anchorBottomLeft">
            <Value name="position" value="30px 30px"/>
            <Value name="size" value="1340px 100px"/>
            <Value name="alignmentY" value="top"/>
            <Value name="flowDirection" value="vertical"/>
        </Profile>

        <Profile name="tourMenuItemControlsItemFirst" extends="tourMenuItemControlsItem">
            <Value name="hasFrame" value="false"/>
        </Profile>

        <Profile name="tourMenuSlider" extends="verticalListSliderRightDocked">

            <Variant name="mobile">
                <Value name="position" value="20px 0px"/>
                <Value name="size" value="12px 700px"/>
            </Variant>
        </Profile>

        <Profile name="tourMenuSliderBar" extends="verticalListSliderBar">

            <Variant name="mobile">
                <Value name="size" value="6px 692px"/>
            </Variant>
        </Profile>
    </GUIProfiles>
</GUI>
