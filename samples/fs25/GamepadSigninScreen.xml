<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onCreate="onCreate" onOpen="onOpen" onClose="onClose">
     <GuiElement type="dynamicFadedBitmap" id="backgroundImage" profile="backgroundImage" />


    <GuiElement type="bitmap" id="backgroundBlurImage" profile="mainScreenSidebar">
        <GuiElement type="dynamicFadedBitmap" id="backgroundBlurFadedBitmap" profile="mainScreenBackgroundBlur" />
        <GuiElement type="bitmap" profile="bgGlow" size="1500px 1080px" position="0 -180px" anchors="1 1 0.5 0.5" />

        <GuiElement type="bitmap" id="logo" profile="mainScreenLogo" />

        <GuiElement type="text" profile="signInText" text="$l10n_ui_consolePressStart" id="startText" />
    </GuiElement>

    <GUIProfiles>
        <Profile name="signInText" extends="textDefault" with="anchorMiddleCenter">
            <Value name="position" value="0 -100px"/>

            <Value name="textSize" value="48px"/>
            <Value name="text2Color" value="0 0 0 1"/>
            <Value name="text2Offset" value="-1px -1px"/>
            <Value name="textAlignment" value="center"/>
            <Value name="textAutoWidth" value="true"/>
            <Value name="textMaxWidth" value="500px"/>
            <Value name="textLayoutMode" value="resize"/>
        </Profile>
    </GUIProfiles>
</GUI>
