<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="settingsHDR">
    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement type="empty" profile="ingameMenuFrameHeaderPanel">
            <GuiElement type="bitmap" profile="ingameMenuDisplaySettingsHeaderIcon" />
            <GuiElement type="text" profile="ingameMenuFrameHeaderText" text="$l10n_setting_hdr"/>
        </GuiElement>

        <!-- Layouted settings box -->
        <GuiElement type="empty" profile="mainMenuSettingsBox" id="settingsContainer">
            <GuiElement type="scrollingLayout" profile="ingameMenuSettingsLayout">
                <GuiElement type="empty" profile="multiTextOptionSettingsWithTitleText" >
                    <GuiElement type="multiTextOption" profile="multiTextOptionSettings" onClick="onClickHDRPeakBrightness" onCreate="onCreateHDRPeakBrightness" id="HDRPeakBrightnessElement" focusInit="onOpen" />
                    <GuiElement type="text"   profile="multiTextOptionSettingsTitle" text="$l10n_setting_hdrPeakBrightness" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="empty" profile="hdrImageBox">
                <GuiElement type="clear" imageUVs="0 0 1 1" anchors="0.5 0.5 0.5 0.5" size="1208px 680px" id="hdrImage" visible="true" />
            </GuiElement>
        </GuiElement>
    </GuiElement>


    <GUIProfiles>
        <Profile name="hdrImageBox" extends="baseReference" with="anchorBottomCenter">
            <Value name="size" value="1208px 680px"/>
        </Profile>
    </GUIProfiles>
</GUI>
