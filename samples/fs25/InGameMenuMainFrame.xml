<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuMain">
    <GuiElement type="empty" profile="uiInGameMenuFrame">

        <GuiElement type="boxLayout" profile="ingameMenuMainLayout" id="container">

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickCalendar" id="calendarButton">
                <GuiElement type="bitmap" profile="ingameMenuMainFrontBg">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconCalendar" />
                </GuiElement>

                <GuiElement type="bitmap" profile="ingameMenuMainContent">
                    <GuiElement type="text" text="$l10n_ui_cropCalendar" profile="ingameMenuMainContentText" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickWeather" focusInit="onOpen" id="weatherButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconWeather" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_ingameMenuWeather" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickPrices" id="pricesButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconPrices" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_prices" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickVehicles" id="vehicleButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconVehicles" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_vehicles" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickFinances" id="financesButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconFinances" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_finances" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickAnimals" id="animalsButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconAnimals" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_ingameMenuAnimals" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickProduction" id="productionButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconProduction" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_production" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickStatistics" id="statisticsButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconStatistics" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_statistics" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickSettings" id="settingsButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconSettings" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_inGameMenuModeSettings" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickHelp" id="helpButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconHelp" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_helpLine" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickHints" id="hintsButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconHints" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_ingameMenuHints" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="button" profile="ingameMenuMainButton" onClick="onClickTour" id="tourButton">
                <GuiElement type="threePartBitmap" profile="ingameMenuMainButtonFrame">
                    <GuiElement type="bitmap" profile="ingameMenuMainFrontIconHints" />
                    <GuiElement type="text" profile="ingameMenuMainContentText" text="$l10n_ui_tour" />
                </GuiElement>
            </GuiElement>

        </GuiElement>
    </GuiElement>


    <GUIProfiles>
